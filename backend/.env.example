# Port for the backend server
PORT=3001

# Optional: default keys if users don't provide their own
# Leave empty to require keys per-request (recommended for multi-user)
DEFAULT_GROQ_KEY=
DEFAULT_SLEZA_KEY=

# CORS: comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL — used for PDF generation (Playwright opens this URL to screenshot)
# In production set to your Vercel URL, e.g.: https://sleza-web.vercel.app
FRONTEND_URL=http://localhost:3000
