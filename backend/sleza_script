// ==UserScript==
// @name         Слеза // Compliance Scanner v7 (Full Site)
// @namespace    https://sleza.media
// @version      7.5.0
// @description  Аудит сайта — контент в приоритете + ЕГРЮЛ + 152-ФЗ чек-лист
// @author       Слеза
// @match        *://*/*
// @grant        GM_xmlhttpRequest
// @grant        GM_addStyle
// @grant        GM_getValue
// @grant        GM_setValue
// @connect      api.groq.com
// @connect      sleza.media
// @connect      egrul.org
// @connect      *
// @run-at       document-end
// ==/UserScript==

(function () {
  'use strict';

  // ── API ключи ─────────────────────────────────
  // Хранятся в Tampermonkey storage (GM_setValue), а не в коде.
  // Первый запуск — кнопка «СЛЕЗА // ПРОВЕРИТЬ» откроет форму ввода.
  // В дальнейшем — кнопка «⚙ Ключи» в шапке модалки.
  // Key storage: GM_getValue/GM_setValue in Tampermonkey; replaceable via setKeyStore() for web.
  let _gmGet = (typeof GM_getValue === 'function') ? GM_getValue : ((_k, d) => d);
  let _gmSet = (typeof GM_setValue === 'function') ? GM_setValue : (() => {});
  function setKeyStore({ get, set }) { _gmGet = get; _gmSet = set; }

  let GROQ_KEY  = _gmGet('GROQ_KEY',  '');
  let SLEZA_KEY = _gmGet('SLEZA_KEY', '');
  function saveKeys(groq, sleza) {
    GROQ_KEY  = (groq  || '').trim();
    SLEZA_KEY = (sleza || '').trim();
    try { _gmSet('GROQ_KEY',  GROQ_KEY);  } catch(_) {}
    try { _gmSet('SLEZA_KEY', SLEZA_KEY); } catch(_) {}
  }

  // HTTP transport: GM_xmlhttpRequest in Tampermonkey; replaceable via setHttpTransport() for web.
  let _httpRequest = (typeof GM_xmlhttpRequest === 'function')
    ? GM_xmlhttpRequest
    : () => { throw new Error('[Слеза] setHttpTransport() не вызван — нет HTTP-транспорта'); };
  function setHttpTransport(fn) { _httpRequest = fn; }
  function hasKeys() { return !!(GROQ_KEY && SLEZA_KEY); }
  // ──────────────────────────────────────────────

  // ── Поведение AI ──────────────────────────────
  // false — Groq НЕ вызывается, отчёт строится только из локальных чек-листов.
  //          Экономит токены / снимает зависимость от rate-limit.
  // true  — Groq вызывается для полировки текста карточек (issue/action),
  //          локальные вердикты по-прежнему перекрывают AI-статус.
  // Также автоматически отключается если GROQ_KEY пустой/placeholder.
  const USE_AI = true;
  // ──────────────────────────────────────────────

  // ── Настройки краулера ────────────────────────
  const MAX_PAGES        = 200;  // максимум страниц для скана
  const MAX_DEPTH        = 2;    // глубина обхода если нет sitemap
  const SLEZA_DELAY_MS   = 1100; // 1 запрос в секунду (лимит API)
  const FETCH_TIMEOUT    = 8000; // таймаут загрузки страницы
  // ──────────────────────────────────────────────

  function escapeHtml(s) {
    return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // Точные формулировки маркировки по категориям.
  // Старый MARK_PATTERNS (substring includes) давал ложные срабатывания
  // на "иностранных дел", "включая", "признан лучшим" → нарушения скрывались.
  const MARK_RE = {
    inoagent: [
      /иностранн[а-яё]*\s+агент/i,
      /иноагент/i,
      /выполня[а-яё]+\s+функци[а-яё]+\s+иностранн[а-яё]+\s+агент/i,
      /включ[её]н[аы]?\s+в\s+(реестр|список|перечень)\s+(иностранн|иноагент)/i,
      /признан[аыо]?\s+(физ[а-яё.\s]*лиц[а-яё]*\s+)?иностранн[а-яё]*\s+агент/i,
      /сми\s*,?\s*выполня[а-яё]+\s+функци[а-яё]+\s+иностранн/i,
    ],
    extremist: [
      /(организаци[яи]|деятельност[ьи])\s+(которой\s+)?запрещен[аы]?\s+(в\s+)?(рф|росси)/i,
      /запрещ[её]нн?[ао]?\s+в\s+(рф|росси)/i,
      /признан[аыо]?\s+(экстремистск|террористич)/i,
      /включ[её]н[аы]?\s+в\s+(перечень|список|реестр)\s+(террористич|экстремистск)/i,
      /(экстремистск|террористич)[а-яё]+\s+(организаци|деятельност|объединени)/i,
    ],
  };
  // terrorist — подмножество extremist с точки зрения маркировки, используем те же паттерны
  MARK_RE.terrorist = MARK_RE.extremist;

  // Сноска со звёздочкой в конце материала: "* — лица, признанные иностранными агентами"
  const STAR_FOOTNOTE_RE = /[\*✱⁕＊][\s\-—–:]{0,4}[^\n\r]{0,200}(иноагент|иностранн[а-яё]*\s+агент|экстремистск|террористич|запрещ[её]н[ао]?\s+в\s+(рф|росси))/i;

  function categorizeMarking(m) {
    const x = m.toLowerCase();
    if (x.includes('иностранн') || x.includes('иноагент')) return 'inoagent';
    if (x.includes('террорист')) return 'terrorist';
    if (x.includes('экстремист') || x.includes('запрещ')) return 'extremist';
    if (x.includes('нежелательн')) return 'undesirable';
    return 'other';
  }

  function escapeRegex(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

  function parseSlezaItem(item) {
    // 💧 — surrogate pair; без non-capturing группы JS-regex без `u`-флага
    // трактует `💧?` как `💧?` (требует high-surrogate), поэтому
    // строки БЕЗ эмодзи перестали матчиться. `(?:💧)?` фиксит это.
    const match = item.match(/^(.+?)\s*\((.+)\)\s*(?:💧)?\s*$/);
    if (!match) return { name: item.trim(), marking: '', category: 'other' };
    const name = match[1].trim();
    const marking = match[2].trim().replace(/💧$/, '').trim();
    return { name, marking, category: categorizeMarking(marking) };
  }

  // Проверка маркировки конкретного упоминания.
  // 1) Локальное окно ±200/+400 вокруг КАЖДОГО вхождения имени (не только первого).
  //    Если в окне найдена формулировка из MARK_RE[category] — промаркировано.
  // 2) Звёздочка после имени + сноска в любом месте текста с ключевыми словами.
  // 3) Имя + маркировка в "хвосте" (последние 3000 симв.) — для дисклеймера в конце.
  function checkMarkingNearby(text, name, category) {
    if (!text || !name) return { found: false };
    const lower = text.toLowerCase();
    const nameLow = name.toLowerCase();
    const idx = lower.indexOf(nameLow);
    if (idx === -1) return { found: false };

    const patterns = MARK_RE[category] || [...MARK_RE.inoagent, ...MARK_RE.extremist];

    // Собираем все позиции имени (учитываем повторные упоминания)
    const positions = [];
    let p = 0;
    while ((p = lower.indexOf(nameLow, p)) !== -1 && positions.length < 20) {
      positions.push(p);
      p += nameLow.length;
    }

    let firstContext = '';

    // (1) Локальное окно ±200/+400 для каждого вхождения
    for (const pos of positions) {
      const start = Math.max(0, pos - 200);
      const end = Math.min(text.length, pos + name.length + 400);
      const window = text.slice(start, end);
      if (!firstContext) firstContext = window;
      if (patterns.some(re => re.test(window))) {
        return { found: true, hasMarking: true, via: 'context', context: window };
      }
    }

    // (2) Звёздочка после имени + сноска ИМЕННО В ХВОСТЕ документа.
    // Раньше сноска искалась во всём тексте → ложные срабатывания: чужая звёздочка
    // у одного имени + чужая сноска у другого → оба ошибочно "промаркированы".
    // Теперь требуем: (а) имя + звёздочка существует, (б) сноска ИЛИ в последних
    // 2000 симв. документа, ИЛИ упоминает фамилию из этого имени.
    const starAfter = new RegExp(escapeRegex(name) + '\\s{0,3}[\\*✱⁕＊]+', 'i');
    if (starAfter.test(text)) {
      // Берём последнее слово из имени как «фамилию» (для большинства ФИО это работает)
      const nameParts = name.trim().split(/\s+/);
      const surname = nameParts[nameParts.length - 1];
      const tailForFootnote = text.slice(Math.max(0, text.length - 2000));
      const footnoteInTail = STAR_FOOTNOTE_RE.test(tailForFootnote);
      // Сноска упоминает фамилию (в любом падеже — strip ending up to 2 chars)
      const surnameStem = surname.length > 4 ? surname.slice(0, -2) : surname;
      const surnameInFootnote = surnameStem.length >= 3 &&
        new RegExp(escapeRegex(surnameStem) + '[а-яё]{0,3}[^а-яё]', 'i').test(tailForFootnote);
      if (footnoteInTail || surnameInFootnote) {
        return { found: true, hasMarking: true, via: 'asterisk', context: firstContext };
      }
    }

    // (3) Хвост: имя + маркировка в последних 3000 симв., в окне ±250 друг от друга
    const tailStart = Math.max(0, text.length - 3000);
    const tail = text.slice(tailStart);
    const tailLow = tail.toLowerCase();
    let tp = 0;
    while ((tp = tailLow.indexOf(nameLow, tp)) !== -1) {
      const ws = Math.max(0, tp - 150);
      const we = Math.min(tail.length, tp + name.length + 250);
      const w = tail.slice(ws, we);
      if (patterns.some(re => re.test(w))) {
        return { found: true, hasMarking: true, via: 'tail', context: w };
      }
      tp += nameLow.length;
    }

    return { found: true, hasMarking: false, via: null, context: firstContext };
  }

  // ── Запросы ───────────────────────────────────
  let scanCancelled = false;
  function setScanCancelled(v) { scanCancelled = !!v; }

  function checkWithSleza(text) {
    return new Promise(resolve => {
      if (scanCancelled) return resolve({ found: 0, items: [], errors: 'cancelled' });
      if (!SLEZA_KEY) {
        try { console.warn('[Слеза] SLEZA_KEY не заполнен — проверка иноагентов/экстремистов недоступна'); } catch(_) {}
        return resolve({ found: 0, items: [], errors: 'no_key' });
      }
      _httpRequest({
        method: 'POST',
        url: 'https://sleza.media/api/parse',
        timeout: 10000,
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + SLEZA_KEY },
        data: JSON.stringify({ text }),
        onload(r) {
          try {
            const parsed = JSON.parse(r.responseText);
            // Лог в консоль — чтобы было видно в DevTools что вернул API
            try { console.log('[Слеза] API response', r.status, parsed); } catch(_) {}
            if (r.status !== 200) {
              return resolve({ found: 0, items: [], errors: 'http_' + r.status, raw: parsed });
            }
            resolve(parsed);
          } catch(e) {
            try { console.warn('[Слеза] API parse fail', r.status, r.responseText?.slice(0, 200)); } catch(_) {}
            resolve({ found: 0, items: [], errors: 'parse_http_' + r.status });
          }
        },
        onerror() { resolve({ found: 0, items: [], errors: 'net' }); },
        ontimeout() { resolve({ found: 0, items: [], errors: 'timeout' }); }
      });
    });
  }

  // ── Извлечение ИНН / ОГРН / ОГРНИП ────────────
  function extractIdentifiers(text) {
    const result = { inn: null, ogrn: null, type: null };
    // ОГРН (13) или ОГРНИП (15) — приоритет, потому что точнее
    // ОГРН (13) или ОГРНИП (15). Порядок альтернатив важен: 15 должен идти первым,
    // иначе на входе "320774600123456" движок жадно матчит первые 13 цифр и теряет ИП.
    const ogrnMatch = text.match(/ОГРН(?:ИП)?[\s:№.]*([0-9]{15}|[0-9]{13})/i);
    if (ogrnMatch) {
      result.ogrn = ogrnMatch[1];
      result.type = ogrnMatch[1].length === 15 ? 'ip' : 'ul';
    }
    // ИНН (10 для ЮЛ, 12 для ИП). Та же причина — 12 должно идти первым.
    const innMatch = text.match(/ИНН[\s:№.]*([0-9]{12}|[0-9]{10})/i);
    if (innMatch) {
      result.inn = innMatch[1];
      if (!result.type) result.type = innMatch[1].length === 12 ? 'ip' : 'ul';
    }
    return result;
  }

  // ── Запрос в egrul.org ────────────────────────
  function checkEgrul(identifier) {
    return new Promise(resolve => {
      if (!identifier || scanCancelled) return resolve(null);
      _httpRequest({
        method: 'GET',
        url: `https://egrul.org/${identifier}.json`,
        timeout: 8000,
        onload(r) {
          try {
            if (r.status !== 200) return resolve({ found: false, error: `http_${r.status}` });
            const data = JSON.parse(r.responseText);
            resolve({ found: true, raw: data, parsed: parseEgrulData(data) });
          } catch(e) { resolve({ found: false, error: 'parse' }); }
        },
        onerror() { resolve({ found: false, error: 'net' }); },
        ontimeout() { resolve({ found: false, error: 'timeout' }); }
      });
    });
  }

  // ── Парсер ответа ФНС (защитный, пробует разные форматы) ──
  function parseEgrulData(data) {
    const r = { name:'', shortName:'', inn:'', ogrn:'', kpp:'', address:'', regDate:'', isActive:true, type:'unknown', reason:'' };
    if (!data) return r;

    // ЮЛ
    const ul = data.СвЮЛ || (data.НаимЮЛПолн ? data : null);
    if (ul) {
      r.type = 'ul';
      r.name = ul.НаимЮЛПолн || ul.СвНаимЮЛ?.НаимЮЛПолн || '';
      r.shortName = ul.НаимЮЛСокр || ul.СвНаимЮЛ?.НаимЮЛСокр || '';
      r.inn = ul.ИНН || '';
      r.ogrn = ul.ОГРН || '';
      r.kpp = ul.КПП || '';
      r.regDate = ul.ДатаОГРН || ul.ДатаРег || '';
      const адресЮЛ = ul.СвАдресЮЛ;
      const адресРФ = ul.АдресРФ;
      if (адресЮЛ) r.address = адресЮЛ.АдресПолн || адресЮЛ.АдресРФ?.АдресПолн || '';
      else if (адресРФ) r.address = адресРФ.АдресПолн || '';
      if (ul.СвПрекрЮЛ || ul.СвСтатус?.КодСтатусЮЛ === '5' || ul.СвЛикв) {
        r.isActive = false;
        r.reason = ul.СвПрекрЮЛ?.НаимСпсПрекрЮЛ || 'Деятельность прекращена';
      }
      return r;
    }
    // ИП
    const ip = data.СвИП || (data.ОГРНИП ? data : null);
    if (ip) {
      r.type = 'ip';
      const f = ip.СвФЛ || ip;
      r.name = `ИП ${f.Фамилия || f.ФамилияИП || ''} ${f.Имя || f.ИмяИП || ''} ${f.Отчество || f.ОтчествоИП || ''}`.trim();
      r.inn = ip.ИННФЛ || ip.ИНН || '';
      r.ogrn = ip.ОГРНИП || ip.ОГРН || '';
      r.regDate = ip.ДатаОГРНИП || ip.ДатаРег || '';
      if (ip.СвПрекрИП || ip.СвСтатус?.КодСтатусИП === '5') {
        r.isActive = false;
        r.reason = 'Деятельность прекращена';
      }
      return r;
    }
    return r;
  }

  // ── Локальный предфильтр: ищем потенциальные упоминания ─
  // Возвращает true если на странице есть паттерны похожие на имена/организации
  function hasNameLikePatterns(text) {
    if (!text || text.length < 100) return false;

    const patterns = [
      // ФИО с отчеством: Иван Иванов Иванович
      /[А-ЯЁ][а-яё]{2,}\s+[А-ЯЁ][а-яё]{2,}\s+[А-ЯЁ][а-яё]{2,}/,
      // Имя Фамилия: Иван Иванов
      /[А-ЯЁ][а-яё]{2,}\s+[А-ЯЁ][а-яё]{2,}/,
      // Инициалы перед фамилией: И.И. Иванов или И. И. Иванов
      /[А-ЯЁ]\.\s*[А-ЯЁ]\.\s*[А-ЯЁ][а-яё]{2,}/,
      // Фамилия с инициалами: Иванов И.И.
      /[А-ЯЁ][а-яё]{2,}\s+[А-ЯЁ]\.\s*[А-ЯЁ]\./,
      // Название в кавычках: «...» или "..."
      /[«"][А-ЯЁA-Z][^»"]{2,50}[»"]/,
      // СМИ + название: «издание "X"», «журнал X», «газета X»
      /(издани[еяю]|газет[ауы]|журнал[аеу]|телеканал|радио|агентств[оау]|медиа|редакци[яюей])/i,
      // Организации: организация X, движение X, объединение X
      /(организаци[яюей]|объединени[ея]|движени[ея]|фонд|сообществ[оау])\s+[«"]/i,
      // Глаголы цитирования: сообщил X, заявил X, написал X, по данным X
      /(сообщил[аи]?|написал[аи]?|заявил[аи]?|по\s+данным|по\s+мнению|рассказал[аи]?|подчеркнул[аи]?)\s+[А-ЯЁ]/i,
      // Известные форматы маркировки (если уже промаркировано — тоже кандидат)
      /\(иностранн[ыо]м?\s+агент/i,
      /(признан[аыо]?\s+иностранн[ыо]м?\s+агент|запрещ[её]н[ао]?\s+в\s+(?:РФ|России))/i
    ];

    return patterns.some(p => p.test(text));
  }

  // ── Чек-лист 152-ФЗ ст.18.1 — 7 обязательных пунктов политики ──
  function check152FZ(policyText) {
    if (!policyText || policyText.length < 100) {
      return { found: 0, total: 7, items: [], status: 'no_policy' };
    }
    const t = policyText.toLowerCase();

    // Section-aware первый проход: заголовки разделов гарантируют пункт.
    // Якорь — НАЧАЛО СТРОКИ (^|\n), затем опциональный префикс "1." / "Раздел 5."
    // Без правильного якоря (?:^|\n) альтернатива \d+\.\s* матчила любую "5." внутри
    // абзаца, превращая section-aware в "найди где угодно после цифры".
    const HEAD = '(?:^|\\n)\\s*(?:\\d+(?:\\.\\d+)*[\\.\\s]+|раздел\\s+\\d+[\\.\\s]+|#{1,6}\\s+)?';
    const sectionHeadingHits = {
      categories:     new RegExp(HEAD + '[^.\\n]{0,30}категори[ийяю][^.\\n]{0,40}(перс|субъект|данн|обрабатыва)', 'i'),
      purposes:       new RegExp(HEAD + '[^.\\n]{0,30}цел[ьеияю][^.\\n]{0,40}(обработк|сбор|использ)', 'i'),
      legal_basis:    new RegExp(HEAD + '[^.\\n]{0,30}(правов[ыоае]+\\s+основан|основани[яею]\\s+обработ|основан[ияе]\\s+для\\s+обработ)', 'i'),
      storage_term:   new RegExp(HEAD + '[^.\\n]{0,30}(срок[аи]?\\s+(хранен|обработк|обрабатыва)|как\\s+долго.{0,20}хран)', 'i'),
      subject_rights: new RegExp(HEAD + '[^.\\n]{0,30}прав[аоеыхими]+\\s+субъект', 'i'),
      contact:        new RegExp(HEAD + '[^.\\n]{0,30}(контакт|реквизит|связ[аь]|обратн[аоы][яе])', 'i'),
      third_parties:  new RegExp(HEAD + '[^.\\n]{0,30}(передач[аеиу]\\s+(данн|перс)|треть[ьиим]+\\s+лиц)', 'i'),
    };

    const checks = [
      {
        id: 'categories',
        label: 'Категории субъектов и персональных данных',
        patterns: [
          /категори[яийюях]+\s+(перс|субъект|обрабатываем|данн)/,
          /перечень.{0,30}(перс|данн|сведени)/,
          /собира[еютюм]+.{0,30}(данн|сведени|информац)/,
          /обрабатыва[еютюмющ]+.{0,40}(данн|сведени|информац)/,
          /(ф\.?и\.?о\.?|фамили[яию]|имя|отчеств)\s*,?\s*(телефон|email|e-?mail|почт|адрес)/,
          /(телефон|email|e-?mail).{0,20}(адрес|почт|номер)/,
        ],
        keywords: ['категории персональных', 'перечень персональных', 'обрабатываемые персональные', 'категории обрабатываемых', 'состав персональных данных', 'виды персональных данных']
      },
      {
        id: 'purposes',
        label: 'Цели обработки персональных данных',
        patterns: [
          /цел[ьейяиюях]+\s+обработк/,
