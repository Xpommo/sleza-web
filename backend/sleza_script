  function findElementByText(searchText) {
    if (!searchText || searchText.length < 5) return null;
    const clean = searchText.replace(/^["«]|["»]$/g, '').trim();
    if (clean.length < 5) return null;
    const w = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
      acceptNode(n) {
        if (!n.textContent || n.textContent.length < 3) return NodeFilter.FILTER_REJECT;
        const p = n.parentElement;
        if (!p || ['SCRIPT','STYLE','NOSCRIPT'].includes(p.tagName)) return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }
    });
    let node;
    while ((node = w.nextNode())) {
      if (node.textContent.includes(clean)) return node.parentElement;
    }
    const short = clean.slice(0, 25);
    const w2 = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
    while ((node = w2.nextNode())) {
      if (node.textContent.includes(short)) {
        const p = node.parentElement;
        if (p && !['SCRIPT','STYLE'].includes(p.tagName)) return p;
      }
    }
    return null;
  }

