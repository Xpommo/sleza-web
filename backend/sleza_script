  let _drugTermsList = null;
  function getDrugRegex() {
    if (_drugRegex) return { re: _drugRegex, terms: _drugTermsList };
    const all = DRUG_TERMS_RAW
      .split('\n')
      .flatMap(l => l.split(';'))
      .map(s => s.trim().toLowerCase())
      .filter(s => s.length >= 3); // отбрасываем слишком короткие (false positives)
    _drugTermsList = [...new Set(all)];
    // Сортируем по убыванию длины — длинные термины должны матчиться раньше коротких
    _drugTermsList.sort((a, b) => b.length - a.length);
    const escaped = _drugTermsList.map(t => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
    // Cyrillic-aware: строгая граница СПЕРЕДИ (защита от false-positive типа "копий"→"опий"),
    // НО без границы сзади — иначе теряем формы "кокаина", "героином", "марихуаны" и т.п.
    // Расчёт: терминов <3 символов нет (отфильтрованы), длинные термины идут первыми
    // в альтернации (longest-match), морфологические окончания добавляются естественно.
    _drugRegex = new RegExp(
      '(?:^|[^а-яёa-z0-9_])(' + escaped.join('|') + ')',
      'gi'
    );
    try { console.log('[Слеза] Drug regex скомпилирован,', _drugTermsList.length, 'уникальных терминов'); } catch(_) {}
    return { re: _drugRegex, terms: _drugTermsList };
  }

  function checkDrugs(fullText) {
    if (!fullText || fullText.length < 100) {
      try { console.log('[Слеза] checkDrugs: текст слишком короткий', fullText?.length || 0); } catch(_) {}
      return { hasMentions: false, status: 'ok', mentions: [], totalMentions: 0, withContext: 0, withoutContext: 0 };
    }
    const { re } = getDrugRegex();
    re.lastIndex = 0; // важно: re глобальный, сбрасываем перед matchAll
    const matches = [...fullText.matchAll(re)];
    try { console.log('[Слеза] checkDrugs: текст', fullText.length, 'симв., совпадений', matches.length); } catch(_) {}
    if (matches.length === 0) {
      return { hasMentions: false, status: 'ok', mentions: [], totalMentions: 0, withContext: 0, withoutContext: 0 };
    }

    // Группируем по термину (учитываем все вхождения).
    // m[0] = (опциональный leading-boundary char) + m[1]. Captured group всегда в конце,
    // поэтому позиция термина = m.index + (m[0].length - m[1].length).
    // indexOf не подходит — он case-sensitive, а regex с флагом /i может вернуть "Героин",
    // что вызовет indexOf("героин") = -1 и смещение на -1.
    const grouped = new Map();
    for (const m of matches) {
      const term = m[1].toLowerCase();
      const pos = m.index + (m[0].length - m[1].length);
      if (!grouped.has(term)) grouped.set(term, []);
      grouped.get(term).push(pos);
    }

    // Для каждого термина проверяем дисклеймер хотя бы возле одного вхождения
    const mentions = [];
    let withContext = 0;
    let withoutContext = 0;
    for (const [term, positions] of grouped.entries()) {
      let hasContext = false;
      for (const pos of positions) {
        const start = Math.max(0, pos - 300);
        const end = Math.min(fullText.length, pos + term.length + 300);
        const window = fullText.slice(start, end);
        if (DRUG_CONTEXT_RE.some(p => p.test(window))) {
          hasContext = true;
          break;
        }
      }
      mentions.push({ term, count: positions.length, hasContext });
      if (hasContext) withContext++;
      else withoutContext++;
    }

    // Сортируем: сначала без контекста (это нарушения), потом с контекстом
    mentions.sort((a, b) => {
      if (a.hasContext !== b.hasContext) return a.hasContext ? 1 : -1;
      return b.count - a.count;
    });

    // Статус:
    // - Все упоминания в контексте → ok
    // - 1-2 без контекста → risk
    // - 3+ без контекста → violation
    let status;
    if (withoutContext === 0) status = 'ok';
    else if (withoutContext <= 2) status = 'risk';
    else status = 'violation';

    return {
      hasMentions: true,
      status,
      totalMentions: matches.length,
      uniqueTerms: grouped.size,
      withContext,
      withoutContext,
      mentions: mentions.slice(0, 15), // первые 15 для UI
    };
  }

  // Определяет, что текущая страница — SPA (React/Vue/Next.js/Angular).
  // Проверяет DOM: корневые контейнеры и путь к бандлированным скриптам.
  function detectSpaFromDom() {
    if (document.querySelector('#root,#app,#__next,#__nuxt,[data-reactroot],[data-v-app],[ng-version]')) return true;
    const scripts = [...document.querySelectorAll('script[src]')];
    return scripts.some(s => /\/_next\/static\/|\/static\/js\/(?:main|bundle|app)\.[a-f0-9]{6}|chunk\.[a-f0-9]{6}/.test(s.src || ''));
  }

  function fetchUrl(url) {
    return new Promise(resolve => {
      if (scanCancelled) return resolve({ url, ok: false, html: '', text: '' });
      _httpRequest({
        method: 'GET', url, timeout: FETCH_TIMEOUT,
        onload(r) {
          try {
            const html = r.responseText || '';
            const stripped = html
              .replace(/<script[\s\S]*?<\/script>/gi, '')
              .replace(/<style[\s\S]*?<\/style>/gi, '')
              .replace(/<noscript[\s\S]*?<\/noscript>/gi, '')
              .replace(/<[^>]+>/g, ' ')
              .replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&')
              .replace(/&lt;/g, '<').replace(/&gt;/g, '>')
              .replace(/&quot;/g, '"').replace(/&#39;/g, "'")
              .replace(/\s+/g, ' ').trim();
            const titleMatch = html.match(/<title[^>]*>([^<]+)<\/title>/i);
            const title = titleMatch ? titleMatch[1].trim() : url;
            resolve({ url, ok: true, html, text: stripped, title });
          } catch(e) { resolve({ url, ok: false, html: '', text: '' }); }
        },
        onerror() { resolve({ url, ok: false, html: '', text: '' }); },
        ontimeout() { resolve({ url, ok: false, html: '', text: '' }); }
      });
    });
  }

  // ── Sitemap ───────────────────────────────────
  // Normalises CDATA-wrapped <loc> before extraction so both
  // <loc>url</loc> and <loc><![CDATA[url]]></loc> are handled.
  function extractLocs(xml) {
    const normalised = xml.replace(/<loc><!\[CDATA\[([\s\S]*?)\]\]><\/loc>/gi, '<loc>$1</loc>');
    return [...normalised.matchAll(/<loc>([^<]+)<\/loc>/g)].map(m => m[1].trim());
  }

  async function trySitemap(origin) {
    const urls = [
      origin + '/sitemap.xml',
      origin + '/sitemap_index.xml',
      origin + '/sitemap-index.xml',
      origin + '/sitemap1.xml',
      origin + '/sitemap-news.xml',
      origin + '/sitemap-posts.xml',
      origin + '/sitemap-articles.xml',
      origin + '/news-sitemap.xml',
      origin + '/post-sitemap.xml',
      origin + '/sitemap/sitemap.xml',
      origin + '/sitemaps/sitemap.xml',
    ];
    for (const u of urls) {
      const r = await fetchUrl(u);
      if (r.ok && (r.html.includes('<loc>') || r.html.includes('<loc><![CDATA['))) {
        const matches = extractLocs(r.html);
        const filtered = matches.filter(url => url.startsWith(origin) && isHtmlUrl(url));
        const subSitemaps = matches.filter(m => m.endsWith('.xml') && m !== u);

        // sitemap-index: ходим по дочерним и собираем URL
        if (subSitemaps.length > 0) {
          const subUrls = [];
          // Берём до 20 sub-sitemaps (часто разбит по годам/категориям — нужны все для покрытия архива)
          for (const sm of subSitemaps.slice(0, 20)) {
            if (scanCancelled) break;
            const sr = await fetchUrl(sm);
            if (sr.ok) {
              subUrls.push(...extractLocs(sr.html).filter(url => url.startsWith(origin) && isHtmlUrl(url)));
            }
          }
          if (subUrls.length > 0) {
            return { source: 'sitemap-index', urls: [...new Set([...filtered, ...subUrls])] };
          }
        }
        if (filtered.length > 0) {
          return { source: 'sitemap', urls: [...new Set(filtered)] };
        }
      }
    }
    return null;
  }

  // Извлечь год публикации из URL: ловит /2019/, /2021-05-15/, /2020/05/, ?date=2018-...
  function extractYearFromUrl(url) {
    const m = url.match(/(?:^|[\/=_\-?&])(20[0-3]\d)(?:[\/=_\-?&]|$)/);
    if (m) {
      const y = parseInt(m[1], 10);
      if (y >= 2010 && y <= 2030) return y;
    }
    return null;
  }

  // Stride-сэмплинг: равномерная выборка N элементов из массива
  function strideSample(arr, n) {
    if (arr.length <= n) return [...arr];
    const step = arr.length / n;
    const result = [];
    for (let i = 0; i < n; i++) result.push(arr[Math.floor(i * step)]);
    return result;
  }

  // Year-bucket сэмплинг: распределяет budget равномерно по годам.
  // Если <3 различных года определилось — fallback на stride-сэмплинг.
  function sampleByYear(urls, budget) {
    if (urls.length <= budget) return [...urls];
    const buckets = new Map();
    for (const u of urls) {
      const y = extractYearFromUrl(u);
      const key = y || 'unknown';
      if (!buckets.has(key)) buckets.set(key, []);
      buckets.get(key).push(u);
    }
    const years = [...buckets.keys()].filter(k => typeof k === 'number').sort();
    if (years.length < 3) return strideSample(urls, budget);

    // Резервируем 15% бюджета на URL без года (главная, секции, статичные)
    const noYear = buckets.get('unknown') || [];
    const noYearShare = Math.min(noYear.length, Math.floor(budget * 0.15));
    const yearBudget = budget - noYearShare;
    const perYear = Math.ceil(yearBudget / years.length);

    const result = [];
    for (const y of years) {
      const bucket = buckets.get(y);
      // Внутри года тоже распределяем равномерно (а не первые N — там вверху обычно свежее)
      result.push(...strideSample(bucket, Math.min(perYear, bucket.length)));
    }
    // URL без года — страйдом
    result.push(...strideSample(noYear, noYearShare));
    return result.slice(0, budget);
  }

  function isHtmlUrl(url) {
    const lower = url.toLowerCase();
    if (/\.(pdf|jpg|jpeg|png|gif|webp|svg|ico|zip|rar|exe|mp3|mp4|mov|css|js|json|xml|woff|woff2|ttf|eot)(\?|$)/.test(lower)) return false;
    if (/(wp-admin|wp-content|wp-includes|admin|api\/|cdn\.|static\.|assets\.)/.test(lower)) return false;
    return true;
  }

  // ── Приоритизация URL по вероятности контента ──
  // Возвращает: 10 = контентная, 7 = главная, 5 = средняя, 3 = обычная, 1 = низкий приоритет, -1 = пропустить
  // Глобальный сборщик причин отброса URL — для диагностики "0 контентных страниц"
  const SKIP_REASONS = new Map(); // pattern → [пример URL, ...]

  function scoreUrl(url) {
    let path = '';
    let queryParamCount = 0;
    try {
      const u = new URL(url);
      path = u.pathname.toLowerCase();
      queryParamCount = [...u.searchParams.keys()].length;
    } catch(e) { return 3; }
    const full = (path + ' ' + url.toLowerCase());

    // Пропускаем URL с большим количеством query-параметров (фильтры, рефералки, варианты)
    if (queryParamCount >= 2) {
      const arr = SKIP_REASONS.get('queryParams>=2') || [];
      if (arr.length < 3) arr.push(url);
      SKIP_REASONS.set('queryParams>=2', arr);
      return -1;
    }

    // Пропускаем технические и каталожные страницы
    const SKIP = [
      // Корзина и заказы
      /\/cart\b/, /\/basket\b/, /\/корзин/,
      /\/checkout\b/, /\/оформ/, /\/order\//, /\/orders\b/, /\/заказ/,
      /\/payment\b/, /\/оплат/, /\/pay\b/,
      /\/shipping\b/, /\/доставк/, /\/delivery\b/,
      // Авторизация
      /\/login\b/, /\/register\b/, /\/signin\b/, /\/signup\b/, /\/войти/, /\/регистр/, /\/auth\b/,
      /\/profile\b/, /\/account\b/, /\/cabinet\b/, /\/личн/,
      // Поиск и фильтры
      /\/search\b/, /\/поиск/,
      /\/filter\b/, /\/фильтр/,
      /\/tag\//, /\/метк/, /\/tags\//,
      /\/category\//, /\/категори/, /\/categories\//,
      // Продукты, каталог, магазин — НЕ нужны для проверки маркировки
      /\/products?\b/, /\/товар/, /\/produkty/,
      /\/catalog\b/, /\/каталог/,
      /\/shop\b/, /\/магазин/, /\/store\b/,
      /\/price\b/, /\/prices\b/, /\/цены/, /\/цена\b/, /\/стоимост/, /\/тариф/, /\/pricing\b/,
      /\/sku\b/, /\/item\//,
      // Технические
      /\/feed\b/, /\/rss\b/,
      /\/sitemap/, /\/карта-сайт/,
      /\/404/, /\/error\b/,
      /\/admin\b/, /\/wp-/, /\/api\b/,
      /\/print\b/, /\/share\b/, /\/preview\b/,
      // Пагинация
      /\/page\/\d+$/, /[?&]page=\d+/, /[?&]p=\d+/
    ];
    const matchedSkip = SKIP.find(p => p.test(full));
    if (matchedSkip) {
      const key = matchedSkip.toString();
      const arr = SKIP_REASONS.get(key) || [];
      if (arr.length < 3) arr.push(url);
      SKIP_REASONS.set(key, arr);
      return -1;
    }

    // ВЫСОКИЙ приоритет — контентные страницы (блог, новости, архивы, публикации)
    const HIGH = [
      // Базовое
      /\/blog/, /\/news/, /\/press/, /\/article/, /\/post/, /\/story/, /\/stories/,
      /\/блог/, /\/новост/, /\/стат(ь|и)/, /\/пресс/, /\/редакция/, /\/медиа/, /\/post/,
      // Публикации и архивы
      /\/publication/, /\/публикаци/, /\/опубликован/,
      /\/archive/, /\/архив/,
      /\/issues?\b/, /\/выпуск/, /\/issue\b/,
      /\/digest/, /\/дайджест/,
      /\/journal/, /\/журнал/, /\/magazine/,
      /\/media\b/, /\/material/, /\/материал/,
      // Контент и колонки
      /\/content\b/, /\/контент/,
      /\/column/, /\/колонк/,
      /\/opinion/, /\/мнения?/, /\/мнение/, /\/editorial/, /\/редакторск/,
      // Исследования и отчёты
      /\/research/, /\/исследовани/,
      /\/report\b/, /\/reports\b/, /\/отчёт/, /\/отчет/,
      /\/analytic/, /\/аналитик/,
      /\/trend/, /\/тренд/,
      /\/case-?stud/, /\/кейс/,
      // Экспертный контент
      /\/insights?/, /\/инсайт/,
      /\/expert/, /\/эксперт/,
      /\/review/, /\/отзыв/, /\/обзор/,
      // События и интервью
      /\/events?\b/, /\/мероприят/,
      /\/interview/, /\/интервью/,
      /\/podcast/, /\/подкаст/,
      // Авторы (часто содержат имена и цитаты)
      /\/author/, /\/автор/, /\/писател/, /\/columnist/,
      // Год/месяц в URL = архивная публикация
      /\/(19|20)\d{2}\//, /\/(19|20)\d{2}-\d{2}/
    ];
    if (HIGH.some(p => p.test(full))) return 10;

    // Главная страница
    if (path === '/' || path === '') return 7;

    // Средний приоритет — корпоративные страницы (нужны для AI: 152-ФЗ, 149-ФЗ, оферта)
    const MED = [
      /\/about/, /\/о-?(нас|компани)/, /\/about-us/,
      /\/team/, /\/команд/, /\/коллектив/,
      /\/career/, /\/работ/, /\/вакан/, /\/jobs/,
      /\/contact/, /\/контакт/,
      /\/portfolio/, /\/портфолио/,
      /\/help/, /\/faq/, /\/помощ/,
      /\/policy/, /\/privacy/, /\/политик/, /\/конфиденц/, /\/persondata/,
      /\/offer/, /\/оферт/, /\/agreement/, /\/договор/, /\/правила/
    ];
    if (MED.some(p => p.test(full))) return 5;

    // Всё остальное
    return 3;
  }

  // ── Краулер (если нет sitemap) ────────────────
  async function crawlSite(startUrl, maxPages, maxDepth, onProgress) {
    const origin = new URL(startUrl).origin;
    const visited = new Set();
    const queued = new Set([startUrl]); // O(1) duplicate check for the queue
    const queue = [{ url: startUrl, depth: 0 }];
    const results = [];

    while (queue.length > 0 && results.length < maxPages && !scanCancelled) {
      const { url, depth } = queue.shift();
      if (visited.has(url)) continue;
      visited.add(url);

      onProgress({ phase: 'crawl', current: results.length, queued: queue.length, url });

      const page = await fetchUrl(url);
      if (!page.ok) continue;
      results.push(url);

      if (depth < maxDepth) {
        const links = [...page.html.matchAll(/href=["']([^"']+)["']/gi)]
          .map(m => m[1])
          .map(href => {
            try { return new URL(href, url).href.split('#')[0]; } catch(e) { return null; }
          })
          .filter(u => u && u.startsWith(origin) && !visited.has(u) && isHtmlUrl(u));

        const unique = [...new Set(links)];
        unique.slice(0, 20).forEach(u => {
          if (!visited.has(u) && !queued.has(u)) {
            queued.add(u);
            queue.push({ url: u, depth: depth + 1 });
          }
        });
      }
    }
    return { source: 'crawl', urls: results };
  }

  // ── DOM helpers ───────────────────────────────
  function getCurrentPageContent() {
    const url = location.href;
    const title = document.title || '';
    const links = Array.from(document.querySelectorAll('a[href]'))
      .map(a => ({
        text: (a.innerText||a.textContent||'').trim().slice(0,80),
        href: a.href,
        path: (() => { try { return new URL(a.href).pathname.toLowerCase(); } catch(e) { return ''; } })()
      }))
      .filter(l => l.text && l.href.startsWith(location.origin));
    const seen = new Set();
    const uniqueLinks = links.filter(l => seen.has(l.href) ? false : (seen.add(l.href), true));

    // Маркеры для классификации ссылок в навигации/футере.
    // Удалены жадные коротыши:
    //   'пд'    → матчился внутри "подкаст", "командировка", "подобн"
    //   'данных' → матчился в "база данных", "управление данных"
    // Оставлены либо длинные стемы, либо URL-фрагменты.
    const KW = {
      policy: ['политик','конфиденц','персональн','privacy','cookie','gdpr','согласие','обработки данн','persdata','personal-data','privacy-policy','/policy','/policies'],
      offer:  ['оферт','договор','правила','усло','public-offer','соглашен','agreement','terms'],
      ret:    ['возврат','обмен','отказ'],
      about:  ['о компани','о нас','контакт','about','contact','реквизит']
    };
    const m = (l, kws) => { const t = (l.text+' '+l.path).toLowerCase(); return kws.some(k => t.includes(k)); };

    const headerEl = document.querySelector('header,#header,.header');
    const footerEl = document.querySelector('footer,#footer,.footer');

    return {
      url, title,
      header: headerEl ? headerEl.innerText.slice(0, 500) : '',
      footer: footerEl ? footerEl.innerText.slice(0, 800) : '',
      bodyText: document.body.innerText.slice(0, 8000),
      links: uniqueLinks.slice(0, 40),
      policyLinks: uniqueLinks.filter(l => m(l, KW.policy)).slice(0, 2),
      offerLinks:  uniqueLinks.filter(l => m(l, KW.offer)).slice(0, 2),
      returnLinks: uniqueLinks.filter(l => m(l, KW.ret)).slice(0, 2),
      aboutLinks:  uniqueLinks.filter(l => m(l, KW.about)).slice(0, 2),
      // Расширенная детекция трекинга — Yandex Metrica, Google Analytics, VK, Mail.ru,
      // Facebook Pixel, Hotjar, Mixpanel, Roistat, AmoCRM, Bitrix24, и т.п.
      hasAdScripts: document.querySelectorAll(
        'script[src*="googletagmanager"],script[src*="google-analytics"],script[src*="gtag"],' +
        'script[src*="mc.yandex"],script[src*="yandex.ru/metrika"],script[src*="yandex.ru/watch"],' +
        'script[src*="vk.com/js"],script[src*="vk-tracker"],script[src*="vk.com/rtrg"],' +
        'script[src*="top.mail.ru"],script[src*="counter.yadro"],' +
        'script[src*="connect.facebook"],script[src*="fbq"],' +
        'script[src*="hotjar"],script[src*="mixpanel"],script[src*="amplitude"],' +
        'script[src*="roistat"],script[src*="bitrix"],script[src*="amocrm"]'
      ).length > 0 ||
        // Inline-инициализация: смотрим только в <head> и в текстовых inline-скриптах,
        // не пересериализуем весь DOM (на крупных новостных сайтах innerHTML = 5-15 МБ).
        (() => {
          const INLINE_RE = /(ym\s*\(\s*\d|gtag\(|fbq\(|_tmr\.push|VK\.Retargeting)/;
          if (document.head && INLINE_RE.test(document.head.innerHTML)) return true;
          const scripts = document.querySelectorAll('script:not([src])');
          for (let i = 0; i < scripts.length && i < 50; i++) {
            if (INLINE_RE.test(scripts[i].textContent || '')) return true;
          }
          return false;
        })(),
      // Cookie-баннер: расширенная детекция
      hasCookieBanner: !!document.querySelector(
        '[class*="cookie"i],[id*="cookie"i],' +
        '[class*="consent"i],[id*="consent"i],' +
        '[class*="gdpr"i],[id*="gdpr"i],' +
        '[class*="privacy-banner"i],[class*="policy-banner"i]'
      ) || /cookie|куки/.test(
        // Ищем явный баннер в первых 50KB DOM с текстом про cookie
        [...document.querySelectorAll('div[role="dialog"],div[role="banner"],aside,[class*="banner"i],[class*="popup"i]')]
