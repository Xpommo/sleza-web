  function renderSlezaCheck(items, title, code, fine, pages, type) {
    const unmarked = items.filter(i => !i.hasMarking);
    const marked = items.filter(i => i.hasMarking);

    let status, issue, action;
    if (items.length === 0) {
      status = 'ok'; issue = 'Упоминаний не найдено на сайте'; action = '—';
    } else if (unmarked.length === 0) {
      status = 'ok';
      issue = `${items.length} ${plural(items.length, 'упоминание','упоминания','упоминаний')} с корректной маркировкой`;
      action = 'Поддерживайте маркировку при новых публикациях';
    } else {
      status = 'violation';
      issue = `${unmarked.length} ${plural(unmarked.length, 'упоминание','упоминания','упоминаний')} БЕЗ маркировки на ${countPagesWith(pages, type)} ${plural(countPagesWith(pages, type), 'странице','страницах','страницах')}`;
      action = 'Добавить маркировку на каждой указанной странице';
    }

    const st = ST[status];
    const pagesBlock = items.length > 0 ? renderPagesList(pages, type) : '';

    return `
      <div class="sz-check ${st.cls}">
        <div class="sz-ct">
          <div>
            <div class="sz-ln">${title}</div>
            <div class="sz-lc">${code} · API Слезы</div>
          </div>
          <div class="sz-pill ${st.cls}">${st.label}</div>
        </div>
        <div class="sz-grid">
          <div class="sz-full">
            <div class="sz-fl">// результат</div>
            <div class="sz-fv iss">${issue}</div>
            ${pagesBlock}
          </div>
          <div>
            <div class="sz-fl">// штраф</div>
            <div class="sz-fv">${fine}</div>
          </div>
          <div>
            <div class="sz-fl">// что нужно сделать</div>
            <div class="sz-fv">${action}</div>
          </div>
        </div>
      </div>`;
  }

  function countPagesWith(pages, type) {
    return pages.filter(p => p.items.some(i =>
      !i.hasMarking && (type === 'inoagent' ? i.category === 'inoagent' : (i.category === 'extremist' || i.category === 'terrorist'))
    )).length;
  }

  function renderPagesList(pages, type) {
    const filtered = pages.filter(p => p.items.some(i =>
      type === 'inoagent' ? i.category === 'inoagent' : (i.category === 'extremist' || i.category === 'terrorist')
    ));
    if (filtered.length === 0) return '';

    return `<div class="sz-pages-list">
      ${filtered.map(p => {
        const relevant = p.items.filter(i =>
          type === 'inoagent' ? i.category === 'inoagent' : (i.category === 'extremist' || i.category === 'terrorist')
        );
        const unmarked = relevant.filter(i => !i.hasMarking);
        const marked = relevant.filter(i => i.hasMarking);
        const isBad = unmarked.length > 0;
        const shortUrl = p.url.replace(location.origin, '') || '/';

        return `<div class="sz-page-item ${isBad ? 'bad' : ''}">
          <a class="sz-page-url" href="${p.url}" target="_blank">${shortUrl}${p.isCurrent ? ' · текущая' : ''}</a>
          <div style="font-family:'Courier New',monospace;font-size:9px;color:#64748b;margin-bottom:4px">
            ${unmarked.length > 0 ? `<span style="color:#f87171;font-weight:700">✗ ${unmarked.length} без маркировки</span>` : ''}
            ${unmarked.length > 0 && marked.length > 0 ? ' · ' : ''}
            ${marked.length > 0 ? `<span style="color:#4ade80">✓ ${marked.length} с маркировкой</span>` : ''}
          </div>
          ${unmarked.length > 0 ? `<div class="sz-page-violations">
            ${unmarked.map(item => `
              <div class="sz-page-violation">
                <span class="name">${escapeHtml(item.name)}</span>
                <span class="mark">→ «${escapeHtml(item.marking.slice(0, 60))}${item.marking.length > 60 ? '...' : ''}»</span>
                ${p.isCurrent ? `<button data-find-name="${encodeURIComponent(item.name)}" data-page-url="${escapeHtml(p.url)}" style="font-family:inherit;font-size:9px;background:#1a2235;border:1px solid #2d3f5a;color:#60a5fa;padding:1px 6px;border-radius:3px;cursor:pointer">📍</button>` : ''}
              </div>
            `).join('')}
          </div>` : ''}
        </div>`;
      }).join('')}
    </div>`;
  }

  function plural(n, one, two, many) {
    const m = n % 10; const m2 = n % 100;
    if (m2 >= 11 && m2 <= 14) return many;
    if (m === 1) return one;
    if (m >= 2 && m <= 4) return two;
    return many;
  }

  // Каждая карточка чек-листа рендерится только в карточке СВОЕГО закона
  // (определяется по explicit `id` в AI_LAW_STUBS, не substring matching).
  function renderAICheck(ch, i, ctx) {
    // ctx = { egrul, result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie }
    const { egrul, result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie } = ctx || {};
    const showLoc = ch.status !== 'ok' && ch.status !== 'unknown' && ch.found_text && !ch.found_text.toLowerCase().includes('отсутств');
    const showQuote = ch.found_text && !ch.found_text.toLowerCase().includes('отсутств') && ch.status !== 'ok';

    // Блок верификации ЕГРЮЛ — только для 149-ФЗ
    const egrulBlock = (egrul && egrul.checked && ch.id === 'law149') ? renderEgrulBlock(egrul) : '';

    // Чек-листы по id — каждый закон рендерится только в своей карточке
    const block152    = (ch.id === 'law152' && result152)   ? render152Block(result152)   : '';
    const blockCookie = (ch.id === 'law152' && resultCookie) ? renderCookieBlock(resultCookie) : '';
    const block149    = (ch.id === 'law149' && result149)   ? render149Block(result149)   : '';
    const blockERIR   = (ch.id === 'erir'   && resultERIR)  ? renderERIRBlock(resultERIR) : '';
    const blockOffer  = (ch.id === 'offer'  && resultOffer) ? renderOfferBlock(resultOffer) : '';
    const blockDrugs  = (ch.id === 'drugs'  && resultDrugs) ? renderDrugsBlock(resultDrugs) : '';

    // Переопределение статуса локальным результатом
    let effectiveStatus = ch.status;
    let effectiveLabel = ST[ch.status]?.label || 'НЕТ ДАННЫХ';
    let effectiveCls = ST[ch.status]?.cls || 'unknown';
    const overrideFromLocal = (localStatus) => {
      if (localStatus === 'ok') { effectiveStatus = 'ok'; effectiveLabel = ST.ok.label; effectiveCls = ST.ok.cls; }
      else if (localStatus === 'risk') { effectiveStatus = 'risk'; effectiveLabel = ST.risk.label; effectiveCls = ST.risk.cls; }
      else if (localStatus === 'violation' || localStatus === 'no_policy') { effectiveStatus = 'violation'; effectiveLabel = ST.violation.label; effectiveCls = ST.violation.cls; }
    };
    if (ch.id === 'law152' && result152) {
      overrideFromLocal(result152.status);
      // Cookie-нарушение может ужесточить статус 152-ФЗ (но не ослабить)
      if (resultCookie && (resultCookie.status === 'violation' || resultCookie.status === 'risk') && effectiveStatus === 'ok') {
        overrideFromLocal('risk');
      }
    }
    if (ch.id === 'law149' && result149) {
      // ЕГРЮЛ может ужесточить статус: организация прекращена → нарушение независимо от чек-листа
      const egrulInactive = egrul?.result?.parsed && egrul.result.parsed.isActive === false;
      overrideFromLocal(egrulInactive ? 'violation' : result149.status);
    }
    if (ch.id === 'erir'  && resultERIR)  overrideFromLocal(resultERIR.status);
    if (ch.id === 'offer' && resultOffer) overrideFromLocal(resultOffer.status);
    if (ch.id === 'drugs' && resultDrugs) overrideFromLocal(resultDrugs.status);

    const hasLocalCheck = block152 || block149 || blockERIR || blockOffer || blockDrugs || blockCookie;

    return `
      <div class="sz-check ${effectiveCls}">
        <div class="sz-ct">
          <div>
            <div class="sz-ln">${escapeHtml(ch.law)}</div>
            <div class="sz-lc">${escapeHtml(ch.law_code)}${egrulBlock ? ' · ЕГРЮЛ' : ''}${hasLocalCheck ? ' · чек-лист' : ''}</div>
          </div>
          <div class="sz-pill ${effectiveCls}">${effectiveLabel}</div>
        </div>
        <div class="sz-grid">
          <div class="sz-full">
            <div class="sz-fl">// что обнаружено</div>
            <div class="sz-fv iss">${escapeHtml(ch.issue || '—')}</div>
            ${egrulBlock}
            ${block152}
            ${blockCookie}
            ${block149}
            ${blockERIR}
            ${blockOffer}
            ${blockDrugs}
            ${showLoc ? `<button class="sz-loc-btn" data-check-idx="${i}"><span class="sz-loc-icon">📍</span><span class="sz-loc-label">${escapeHtml(ch.location || 'на странице')}</span></button>` : ''}
            ${showQuote ? `<div class="sz-quote">"${escapeHtml(ch.found_text)}"</div>` : ''}
          </div>
          <div>
            <div class="sz-fl">// штраф</div>
            <div class="sz-fv">${escapeHtml(ch.fine || '—')}</div>
          </div>
          <div>
            <div class="sz-fl">// что нужно сделать</div>
            <div class="sz-fv">${escapeHtml(ch.action || '—')}</div>
          </div>
        </div>
      </div>`;
  }

  // Общая оболочка для всех чек-листов (152-ФЗ, 149-ФЗ, ЕРИР, Оферта, Наркотики, Cookie).
  // status → cls/icon, title и desc передаются как готовые строки, itemsHtml — заранее
  // отрендеренные строки с <div class="sz-152-row">. Это убирает ~6 одинаковых
  // оболочек по 8-10 строк каждая.
  function renderChecklistShell({ status, title, itemsHtml, desc, titlePrefix }) {
    const cls = status === 'ok' ? 'good' : status === 'risk' ? 'warn' : status === 'no_policy' ? 'bad' : 'bad';
    const icon = status === 'ok' ? '✓' : status === 'risk' ? '⚠' : '✗';
    const prefix = titlePrefix ? `${titlePrefix} — ` : '';
    return `<div class="sz-egrul-block ${cls}">
      <div class="sz-egrul-title">${icon} ${prefix}${escapeHtml(title)}</div>
      ${itemsHtml ? `<div class="sz-152-list">${itemsHtml}</div>` : ''}
      <div class="sz-egrul-desc">${desc}</div>
    </div>`;
  }
  // Простая строка чек-листа: галочка/крестик + лейбл. Используется большинством блоков.
  function checklistRow({ present, label, extra }) {
    const iconChar = present ? '✓' : '✗';
    const iconCls = present ? 'ok' : 'miss';
    return `<div class="sz-152-row">
        <span class="sz-152-icon ${iconCls}">${iconChar}</span>
        <span class="sz-152-label ${present ? '' : 'miss'}">${escapeHtml(label)}${extra || ''}</span>
      </div>`;
  }

  function renderCookieBlock(r) {
    if (!r) return '';
    const trackDot = r.hasTracking ? '🔴' : '⚪';
    const bannerDot = r.hasCookieBanner ? '🟢' : '⚪';
    const itemsHtml = [
      `<div class="sz-152-row"><span class="sz-152-icon ${r.hasTracking ? 'miss' : 'ok'}">${trackDot}</span><span class="sz-152-label">Аналитический трекинг: ${r.hasTracking ? 'обнаружен (Метрика / GA / Pixel)' : 'не обнаружен'}</span></div>`,
      `<div class="sz-152-row"><span class="sz-152-icon ${r.hasCookieBanner ? 'ok' : 'miss'}">${bannerDot}</span><span class="sz-152-label">Cookie-баннер: ${r.hasCookieBanner ? 'присутствует' : 'отсутствует'}</span></div>`,
      `<div class="sz-152-row"><span class="sz-152-icon ${r.policyHasCookies ? 'ok' : 'miss'}">${r.policyHasCookies ? '✓' : '✗'}</span><span class="sz-152-label">Cookies упоминаются в политике: ${r.policyHasCookies ? 'да' : 'нет'}</span></div>`,
    ].join('');
    return renderChecklistShell({
      status: r.status,
      titlePrefix: 'Cookie-compliance',
      title: r.title,
      itemsHtml,
      desc: escapeHtml(r.message),
    });
  }

  function render152Block(r) {
    // Политика не найдена
    if (r.status === 'no_policy') {
      return renderChecklistShell({
        status: 'no_policy',
        title: 'Политика конфиденциальности НЕ НАЙДЕНА',
        itemsHtml: '',
        desc: 'По 152-ФЗ оператор обязан опубликовать политику конфиденциальности с 7 обязательными пунктами (ст. 18.1).',
      });
    }
    const title = r.status === 'ok' ? `Политика полная (${r.found} из ${r.total})` :
                  r.status === 'risk' ? `Политика неполная (${r.found} из ${r.total})` :
                  `Критические пробелы (${r.found} из ${r.total})`;
    const itemsHtml = r.items.map(item => {
      const isAi = item.present && item.confirmedBy === 'ai';
      const iconChar = item.present ? (isAi ? '◆' : '✓') : '✗';
      const iconCls = item.present ? (isAi ? 'ai' : 'ok') : 'miss';
      const titleAttr = isAi && item.quote ? ` title="Подтверждено AI: «${escapeHtml(item.quote)}»"` : '';
      const aiTag = isAi ? ' <span style="font-family:\'Courier New\',monospace;font-size:9px;color:#60a5fa">· AI</span>' : '';
      return `<div class="sz-152-row"${titleAttr}>
        <span class="sz-152-icon ${iconCls}">${iconChar}</span>
        <span class="sz-152-label ${item.present ? '' : 'miss'}">${escapeHtml(item.label)}${aiTag}</span>
      </div>`;
    }).join('');
    const missingItems = r.items.filter(i => !i.present);
    const aiCount = r.items.filter(i => i.present && i.confirmedBy === 'ai').length;
    let desc;
    if (missingItems.length > 0) {
      desc = `Отсутствует: ${escapeHtml(missingItems.map(i => i.label.toLowerCase()).join('; '))}.`;
    } else if (aiCount > 0) {
      desc = `Политика содержит все обязательные пункты по ст. 18.1 152-ФЗ (${aiCount} ${aiCount === 1 ? 'пункт подтверждён' : 'пунктов подтверждено'} AI после локального чек-листа).`;
    } else {
      desc = 'Политика содержит все обязательные пункты по ст. 18.1 152-ФЗ.';
    }
    return renderChecklistShell({ status: r.status, title, itemsHtml, desc });
  }

  function render149Block(r) {
    const title = r.status === 'ok' ? `Реквизиты полные (${r.found} из ${r.total})` :
                  r.status === 'risk' ? `Реквизиты неполные (${r.found} из ${r.total})` :
                  `Критические пробелы (${r.found} из ${r.total})`;
    const itemsHtml = r.items.map(item => checklistRow({ present: item.present, label: item.label })).join('');
    const missing = r.items.filter(i => !i.present);
    const desc = missing.length > 0
      ? `Отсутствует на сайте: ${escapeHtml(missing.map(i => i.label.toLowerCase()).join('; '))}.`
      : 'Все обязательные реквизиты владельца указаны на сайте.';
    return renderChecklistShell({ status: r.status, title, itemsHtml, desc });
  }

  function renderERIRBlock(r) {
    if (!r.hasAdContent) {
      return renderChecklistShell({
        status: 'ok',
        title: 'Рекламный контент не обнаружен',
        itemsHtml: '',
        desc: 'Сайт не содержит признаков интернет-рекламы — маркировка ЕРИР не требуется. Если реклама размещается динамически (через JS), проверка может быть неточной.',
      });
    }
    const title = r.status === 'ok' ? `Реклама маркирована (${r.found} из ${r.total})` :
                  r.status === 'risk' ? `Маркировка неполная (${r.found} из ${r.total})` :
                  `Реклама без маркировки (${r.found} из ${r.total})`;
    const itemsHtml = r.items.map(item => checklistRow({ present: item.present, label: item.label })).join('');
    const missing = r.items.filter(i => !i.present);
    const desc = missing.length > 0
      ? `Отсутствует: ${escapeHtml(missing.map(i => i.label.toLowerCase()).join('; '))}. С 01.09.2022 интернет-реклама без токена ERID — штраф до 500 000 руб.`
      : 'Рекламный контент маркирован корректно: токен ERID, метка «реклама», информация о рекламодателе на месте.';
    return renderChecklistShell({ status: r.status, title, itemsHtml, desc });
  }

  function renderOfferBlock(r) {
    if (!r.isCommercial) {
      return renderChecklistShell({
        status: 'ok',
        title: 'Информационный сайт',
        itemsHtml: '',
        desc: 'Признаков торговой / SaaS-деятельности не обнаружено — публичная оферта и условия возврата не обязательны.',
      });
    }
    const kindLabel = r.kind === 'saas' ? 'SaaS / лицензионный договор' :
                      r.kind === 'ecommerce' ? 'E-commerce / товары' :
                      r.kind === 'services' ? 'B2B-услуги / договор подряда' :
                      'Коммерческая деятельность';
    const title = r.status === 'ok' ? `Оферта на месте (${r.found} из ${r.total}) · ${kindLabel}` :
                  r.status === 'risk' ? `Оферта неполная (${r.found} из ${r.total}) · ${kindLabel}` :
                  `Критические пробелы (${r.found} из ${r.total})`;
    const itemsHtml = r.items.map(item => checklistRow({ present: item.present, label: item.label })).join('');
    const missing = r.items.filter(i => !i.present);
    const desc = missing.length > 0
      ? `Отсутствует: ${escapeHtml(missing.map(i => i.label.toLowerCase()).join('; '))}. По ЗоЗПП покупатель имеет право вернуть товар в течение 7 дней — это должно быть указано на сайте.`
      : 'Все обязательные элементы публичной оферты на месте: договор, условия возврата, реквизиты продавца и контакты.';
    return renderChecklistShell({ status: r.status, title, itemsHtml, desc });
  }

  function renderDrugsBlock(r) {
    if (!r.hasMentions) {
      return renderChecklistShell({
        status: 'ok',
        title: 'Упоминаний запрещённых веществ не обнаружено',
        itemsHtml: '',
        desc: 'Сканирование по базе из ~900 терминов (вещества, сленг, прекурсоры) не нашло совпадений.',
      });
    }
    const title = r.status === 'ok'
      ? `Упоминания в допустимом контексте (${r.totalMentions} вхождений)`
      : r.status === 'risk'
        ? `Упоминания без контекста — ${r.withoutContext} из ${r.uniqueTerms}`
        : `Упоминания без дисклеймера — ${r.withoutContext} из ${r.uniqueTerms}`;
    const itemsHtml = r.mentions.map(m => {
      const note = m.hasContext ? 'в контексте (УК/медицина/новости)' : 'без явного контекста';
      return checklistRow({
        present: m.hasContext,
        label: `«${m.term}» (×${m.count}) — ${note}`,
      });
    }).join('');
    const desc = r.status === 'ok'
      ? 'Все упоминания сопровождаются контекстом (статья УК, медицина, профилактика, новость о борьбе с наркотиками).'
      : r.status === 'risk'
        ? `Найдено ${r.withoutContext} упоминаний без явного юридического/медицинского контекста — рекомендуется добавить дисклеймер или удалить.`
        : `Найдено ${r.withoutContext} упоминаний без дисклеймера. По ст.6.13 КоАП — пропаганда наркотиков: штраф до 1 500 000 руб.`;
    return renderChecklistShell({ status: r.status, title, itemsHtml, desc });
  }

  function renderEgrulBlock(egrul) {
    const ids = egrul.ids;
    const res = egrul.result;

    // Реквизиты не найдены на сайте
    if (!ids.inn && !ids.ogrn) {
      return `<div class="sz-egrul-block bad">
        <div class="sz-egrul-title">⚠ Реквизиты НЕ НАЙДЕНЫ на сайте</div>
        <div class="sz-egrul-desc">По 149-ФЗ ст.10 ИНН и ОГРН должны быть размещены публично — обычно в подвале или на странице "О компании".</div>
      </div>`;
    }

    // Реквизиты найдены, но не проверены или не нашлись в ФНС
    if (!res || !res.found) {
      return `<div class="sz-egrul-block warn">
        <div class="sz-egrul-title">⚠ ИНН/ОГРН не подтверждён в ФНС</div>
        <div class="sz-egrul-row"><span>На сайте:</span> ИНН ${escapeHtml(ids.inn||'—')}, ОГРН ${escapeHtml(ids.ogrn||'—')}</div>
        <div class="sz-egrul-row"><span>Ошибка:</span> ${escapeHtml(res?.error || 'данные не вернулись')}</div>
        <div class="sz-egrul-desc">Возможно: ИНН неверный, организация ликвидирована, или сервис временно недоступен.</div>
      </div>`;
    }

    // ВСЁ ОК
    const p = res.parsed;
    const cls = p.isActive ? 'good' : 'bad';
    const statusIcon = p.isActive ? '✓' : '✗';
    return `<div class="sz-egrul-block ${cls}">
      <div class="sz-egrul-title">${statusIcon} Реквизиты сверены с ФНС</div>
      <div class="sz-egrul-row"><span>Тип:</span> ${p.type === 'ip' ? 'Индивидуальный предприниматель' : 'Юридическое лицо'}</div>
      <div class="sz-egrul-row"><span>Название:</span> ${escapeHtml(p.name || '—')}</div>
      ${p.inn ? `<div class="sz-egrul-row"><span>ИНН:</span> ${escapeHtml(p.inn)}</div>` : ''}
      ${p.ogrn ? `<div class="sz-egrul-row"><span>ОГРН:</span> ${escapeHtml(p.ogrn)}</div>` : ''}
      ${p.kpp ? `<div class="sz-egrul-row"><span>КПП:</span> ${escapeHtml(p.kpp)}</div>` : ''}
      ${p.address ? `<div class="sz-egrul-row"><span>Адрес:</span> ${escapeHtml(p.address)}</div>` : ''}
      ${p.regDate ? `<div class="sz-egrul-row"><span>Дата рег.:</span> ${escapeHtml(p.regDate)}</div>` : ''}
      <div class="sz-egrul-row"><span>Статус:</span> <strong class="${p.isActive ? 'ok' : 'bad'}">${p.isActive ? 'ДЕЙСТВУЮЩАЯ' : 'ПРЕКРАЩЕНА'}</strong></div>
      ${!p.isActive && p.reason ? `<div class="sz-egrul-desc">${escapeHtml(p.reason)} — критическое нарушение, сайт нельзя использовать для коммерческой деятельности.</div>` : ''}
    </div>`;
  }

  // ── Экспорт чистых функций для тестов (Node/vitest) ─────────────
  // В Tampermonkey `module` undefined и блок игнорируется.
  if (typeof module !== 'undefined' && module.exports) {
    module.exports = {
      escapeHtml, escapeRegex,
      parseSlezaItem, checkMarkingNearby, checkWithSleza,
      extractIdentifiers, checkEgrul, parseEgrulData,
      hasNameLikePatterns,
      check152FZ, check149FZ, checkERIR, checkCookieCompliance,
      checkOffer, getDrugRegex, checkDrugs,
      scoreUrl, isHtmlUrl, extractYearFromUrl, strideSample, sampleByYear,
      fetchUrl, trySitemap, crawlSite, discoverPolicyByCommonPaths, extractLocs,
      runAIAnalysis, verify152FZWithAI,
      buildLocalChecks, plural,
      setHttpTransport, setKeyStore, saveKeys, setScanCancelled,
    };
  }
})();
