  function highlightElement(el) {
    if (!el) return false;
    if (activeHighlight) {
      activeHighlight.style.outline = ''; activeHighlight.style.outlineOffset = '';
      activeHighlight.style.backgroundColor = '';
    }
    activeHighlight = el;
    el.style.transition = 'outline-color 0.4s, background-color 0.4s';
    el.style.outline = '3px solid #ef4444'; el.style.outlineOffset = '4px';
    el.style.backgroundColor = 'rgba(239,68,68,0.12)';
