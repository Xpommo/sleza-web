  function showProgress({ phase, current, total, queued, url, found, skipped }) {
    const bd = document.getElementById('sz-bd');
    if (!bd) return;
    const pct = total > 0 ? Math.round((current / total) * 100) : 0;
    const phaseText = {
      'sitemap': 'Поиск sitemap.xml',
      'crawl': 'Обход сайта',
      'sleza': 'Проверка по реестру Слезы',
      'ai': 'AI-анализ остальных законов',
    }[phase] || phase;

    bd.innerHTML = `
      <div class="sz-progress">
        <div class="sz-spinner"></div>
        <div class="sz-prog-title">${phaseText}</div>
        <div class="sz-prog-stage">${url ? '→ ' + escapeHtml(url.slice(0, 80)) : ''}</div>
        ${total > 0 ? `<div class="sz-prog-bar"><div class="sz-prog-fill" style="width:${pct}%"></div></div>` : ''}
        <div class="sz-prog-stats">
          ${total > 0 ? `<span>${current}</span> из <span>${total}</span> страниц` : ''}
          ${queued !== undefined ? `· в очереди: <span>${queued}</span>` : ''}
          ${skipped !== undefined && skipped > 0 ? `· <span style="color:#4ade80">⚡ пропущено фильтром: <strong>${skipped}</strong></span>` : ''}
        </div>
        ${found ? `<div class="sz-found-live">
          <div><span class="lbl">найдено упоминаний:</span> <span class="num ${found.total === 0 ? 'zero' : ''}">${found.total}</span></div>
          <div><span class="lbl">без маркировки:</span> <span class="num ${found.unmarked === 0 ? 'zero' : ''}">${found.unmarked}</span></div>
        </div>` : ''}
        <button class="sz-cancel-btn" id="sz-cancel-btn">✕ Отменить</button>
      </div>`;
    const cancelBtn = document.getElementById('sz-cancel-btn');
    if (cancelBtn) cancelBtn.addEventListener('click', () => { scanCancelled = true; });
  }

  // ── Сценарий: одна страница ───────────────────
  async function runSinglePageScan() {
    SKIP_REASONS.clear();
    showProgress({ phase: 'sleza', current: 0, total: 1, url: location.href });
    const c = getCurrentPageContent();
    const fullText = `${c.title}\n${c.header}\n${c.bodyText}\n${c.footer}`;

    const slezaResult = await checkWithSleza(fullText);
    const items = (slezaResult.items || []).map(parseSlezaItem);
    const checked = items.map(item => ({ ...item, ...checkMarkingNearby(fullText, item.name, item.category), pageUrl: location.href }));

    // ЕГРЮЛ-проверка реквизитов
    showProgress({ phase: 'sleza', current: 1, total: 1, url: 'Проверка ЕГРЮЛ...' });
    const ids = extractIdentifiers(fullText);
    let egrulResult = null;
    if (ids.ogrn || ids.inn) {
      egrulResult = await checkEgrul(ids.ogrn || ids.inn);
    }
    const egrul = { checked: true, ids, result: egrulResult };

    showProgress({ phase: 'ai', current: 1, total: 1 });
    const aiData = await runAIAnalysis(c, egrul, fullText);

    renderResults({
      mode: 'single',
      origin: location.origin,
      hostname: location.hostname,
      pages: [{ url: location.href, title: c.title, items: checked, isCurrent: true }],
      aiData,
      egrul,
      slezaError: slezaResult.errors || null,
      spaWarning: detectSpaFromDom(),
    });
  }

  // ── Сценарий: весь сайт ──────────────────────
  async function runFullSiteScan() {
    const origin = location.origin;
    const hostname = location.hostname;

    // 1. Получаем список URL
    showProgress({ phase: 'sitemap', current: 0, total: 0, url: origin });
    let urlList = await trySitemap(origin);
    if (scanCancelled) return;

    if (!urlList || urlList.urls.length === 0) {
      showProgress({ phase: 'crawl', current: 0, total: MAX_PAGES, url: origin });
      urlList = await crawlSite(location.href, MAX_PAGES, MAX_DEPTH, p => {
        if (!scanCancelled) showProgress({ phase: 'crawl', current: p.current, total: MAX_PAGES, queued: p.queued, url: p.url });
      });
    }
    if (scanCancelled) return;

    let urls = urlList.urls;
    const totalDiscovered = urls.length;

    // ── Стратегия отбора: HIGH-контент с покрытием по годам ──
    SKIP_REASONS.clear(); // Сбрасываем диагностику с прошлого скана
    let scored = urls
      .map(u => ({ url: u, score: scoreUrl(u) }))
      .filter(x => x.score >= 0); // отбрасываем технические страницы

    // Fallback: если SKIP-фильтр отбросил >95% URL — нестандартная структура сайта.
    // Логируем причины и берём все URL как LOW, чтобы хоть что-то просканировать.
    let usedFallback = false;
    if (scored.length === 0 && totalDiscovered > 0) {
      try {
        console.warn('[Слеза] scoreUrl отбросил все', totalDiscovered, 'URL. Топ-причины:');
        for (const [pattern, examples] of SKIP_REASONS.entries()) {
          console.warn('  •', pattern, '→', examples.slice(0, 3));
        }
        console.warn('[Слеза] Fallback: использую все URL как LOW (приоритет 3).');
      } catch(_) {}
      scored = urls.map(u => ({ url: u, score: 3 }));
      usedFallback = true;
    }

    const highPages = scored.filter(x => x.score >= 10).map(x => x.url);
    const medPages  = scored.filter(x => x.score === 5 || x.score === 7).map(x => x.url);
    const lowPages  = scored.filter(x => x.score === 3).map(x => x.url);

    // Бюджет: MED ≤10 (корпоративные нужны для 152/149/оферты), остальное под HIGH, остаток LOW.
    const medBudget = Math.min(medPages.length, 10);
    const lowBudget = Math.min(lowPages.length, Math.max(0, Math.min(20, MAX_PAGES - highPages.length - medBudget)));
    const highBudget = Math.max(0, MAX_PAGES - medBudget - lowBudget);

    // HIGH-страницы сэмплируем по годам — гарантирует покрытие архива до и после 2022
    const highSampled = sampleByYear(highPages, highBudget);
    const medSampled  = medPages.slice(0, medBudget); // корпоративные не сэмплируем по годам
    const lowSampled  = strideSample(lowPages, lowBudget);

    // Главная всегда первая
    const all = [...highSampled, ...medSampled, ...lowSampled];
    const withoutCurrent = all.filter(u => u !== location.href);
    urls = [location.href, ...withoutCurrent].slice(0, MAX_PAGES);

    // Подсчёт лет в финальной выборке — для статистики в UI
    const yearsSet = new Set();
    for (const u of urls) {
      const y = extractYearFromUrl(u);
      if (y) yearsSet.add(y);
    }

    // Статистика по типам
    const yearsSorted = [...yearsSet].sort();
    const stats = {
      high: highPages.length,
      highScanned: highSampled.length,
      mid: medBudget,
      low: lowSampled.length,
      skipped: totalDiscovered - scored.length,
      totalHighFound: highPages.length,
      yearsCovered: yearsSorted,
      yearRange: yearsSorted.length > 0 ? `${yearsSorted[0]}–${yearsSorted[yearsSorted.length-1]}` : null,
      usedFallback,
      totalDiscovered,
    };

    // 2. Сканируем каждую страницу через API Слезы
    const pages = [];
    let totalUnmarked = 0;
    let totalFound = 0;
    let skippedByFilter = 0; // счётчик пропущенных предфильтром
    let allPagesRawText = ''; // накапливаем хвосты страниц для поиска ИНН/ОГРН в подвалах
    let firstSlezaError = null; // первая ошибка API Слезы (для диагностики)
    let spaLikeCount = 0; // страниц с признаками SPA-оболочки (мало текста, большой HTML)

    for (let i = 0; i < urls.length; i++) {
      if (scanCancelled) break;
      const url = urls[i];
      const score = scoreUrl(url);
      const typeLabel = score >= 10 ? '📰 контент' : score >= 7 ? '🏠 главная' : score >= 5 ? '🏢 корпоративн.' : '📄 страница';

      showProgress({
        phase: 'sleza', current: i, total: urls.length,
        url: `${typeLabel} · ${url.replace(location.origin, '')}`,
        found: { total: totalFound, unmarked: totalUnmarked },
        skipped: skippedByFilter
      });

      let pageData;
      if (url === location.href) {
        // Текущая страница — берём из DOM (быстрее и точнее)
        const c = getCurrentPageContent();
        pageData = {
          url, ok: true,
          text: `${c.title}\n${c.header}\n${c.bodyText}\n${c.footer}`,
          title: c.title
        };
      } else {
        pageData = await fetchUrl(url);
        // Считаем SPA-оболочки: мало текста при большом HTML — JS-рендеринг
        if (pageData.ok && pageData.text.length < 200 && (pageData.html || '').length > 3000) {
          spaLikeCount++;
        }
      }

      if (!pageData.ok || !pageData.text) {
        pages.push({ url, title: pageData.title || url, items: [], error: 'не загружено', isCurrent: url === location.href });
        continue;
      }

      // ── ПРЕДФИЛЬТР: пропускаем страницы без признаков имён ──
      if (!hasNameLikePatterns(pageData.text)) {
        // Хвост — для ЕГРЮЛ: ИНН/ОГРН часто в подвале даже у страниц без имён (/contacts, /about)
        allPagesRawText += ' ' + pageData.text.slice(-1500);
        pages.push({
          url, title: pageData.title, items: [],
          skipped: true, // помечаем как пропущенную
          isCurrent: url === location.href
        });
        skippedByFilter++;
        continue; // НЕ тратим API-запрос, НЕ делаем задержку
      }

      const slezaResult = await checkWithSleza(pageData.text);
      if (slezaResult.errors && !firstSlezaError) firstSlezaError = slezaResult.errors;
      const items = (slezaResult.items || []).map(parseSlezaItem);
      const checked = items.map(item => ({ ...item, ...checkMarkingNearby(pageData.text, item.name, item.category), pageUrl: url }));

      const unmarkedCount = checked.filter(x => !x.hasMarking).length;
      totalFound += checked.length;
      totalUnmarked += unmarkedCount;

      // Хвост страницы (1500 симв.) — подвалы часто содержат ИНН/ОГРН
      allPagesRawText += ' ' + pageData.text.slice(-1500);

      pages.push({
        url, title: pageData.title, items: checked,
        isCurrent: url === location.href
      });

      // Задержка перед следующим запросом (только если был API-запрос)
      if (i < urls.length - 1 && !scanCancelled) {
        await new Promise(r => setTimeout(r, SLEZA_DELAY_MS));
      }
    }

    if (scanCancelled) {
      const bd = document.getElementById('sz-bd');
      if (bd) bd.innerHTML = `<div class="sz-err">⚠ Сканирование отменено<br><br><small>Просканировано ${pages.length} страниц</small></div>`;
      return;
    }

    // 3. AI-анализ остальных законов (только на главной)
    showProgress({ phase: 'ai', current: urls.length, total: urls.length, found: { total: totalFound, unmarked: totalUnmarked } });
    const c = getCurrentPageContent();

    // ЕГРЮЛ-проверка: объединяем хвосты всех страниц + DOM текущей (подвал = главный источник ИНН/ОГРН)
    const allPagesText = allPagesRawText + ' ' + c.bodyText + ' ' + c.footer + ' ' + c.header;
    const ids = extractIdentifiers(allPagesText);
    let egrulResult = null;
    if (ids.ogrn || ids.inn) {
      egrulResult = await checkEgrul(ids.ogrn || ids.inn);
    }
    const egrul = { checked: true, ids, result: egrulResult };

    const aiData = await runAIAnalysis(c, egrul, allPagesText);

    const spaWarning = detectSpaFromDom() || (urls.length > 3 && spaLikeCount / urls.length > 0.3);
    renderResults({ mode: 'full', origin, hostname, pages, aiData, source: urlList.source, egrul, stats, slezaError: firstSlezaError, spaWarning });
  }

  // Пытается найти политику по типовым URL-путям, если ссылок в DOM не нашлось
  // или текст оказался слишком коротким (SPA-оболочка, нестандартный текст линка).
  // Возвращает [{url, text}] или [] если нигде не получилось.
  async function discoverPolicyByCommonPaths(originUrl) {
    if (scanCancelled) return [];
    let origin;
    try { origin = new URL(originUrl).origin; } catch (e) { return []; }

    // Две волны: сначала 5 самых частых путей параллельно — если нашли, не идём дальше.
    // Вторая волна — оставшиеся 9. Это убирает 8 с задержку по 8 с на SPA-сайтах.
    const wave1 = ['/privacy-policy', '/privacy', '/policy', '/personal-data', '/legal/privacy'];
    const wave2 = [
      '/legal/privacy-policy', '/info/privacy', '/about/privacy',
      '/static/privacy', '/static-pages/privacy', '/policies/privacy',
      '/privacy.html', '/privacy.shtml', '/persdata',
    ];

    function isPolicyPage(r) {
      if (!r || !r.ok || !r.text || r.text.length < 500) return false;
      const t = r.text.toLowerCase();
      return t.includes('персональн') || t.includes('privacy') ||
             t.includes('конфиденц')   || t.includes('обработк');
    }

    for (const wave of [wave1, wave2]) {
      if (scanCancelled) return [];
      const results = await Promise.all(wave.map(p => fetchUrl(origin + p)));
      if (scanCancelled) return [];
      const found = results.filter(isPolicyPage);
      if (found.length > 0) {
        found.sort((a, b) => b.text.length - a.text.length);
        return [{ url: found[0].url, text: found[0].text.slice(0, 50000) }];
      }
    }
    return [];
  }

  // ── AI-арбитр для 152-ФЗ: подтверждает пункты, которые локальный чек не нашёл ──
  // Вызывается ТОЛЬКО при неуверенном результате (1 ≤ found ≤ 5). Никогда не понижает статус.
  async function verify152FZWithAI(policyText, result152) {
    if (!policyText || result152.found >= 6 || result152.found === 0 || result152.status === 'no_policy') {
      return result152;
    }
    if (scanCancelled) return result152;

    const missing = result152.items.filter(i => !i.present);
    if (missing.length === 0) return result152;

    const policySnippet = policyText.slice(0, 30000);

    const system = `Ты эксперт по 152-ФЗ. Тебе дан текст политики конфиденциальности и список обязательных пунктов ст. 18.1, которые локальный регулярный поиск НЕ нашёл. Твоя задача: для КАЖДОГО пункта решить — есть ли он на самом деле в тексте политики.

Правила:
- present: true — если пункт явно присутствует в тексте, пусть и сформулирован нестандартно
- present: false — если пункта действительно нет
- quote — короткий фрагмент (15-60 симв.) из политики, доказывающий наличие пункта (только если present: true)
- Не придумывай. Сомневаешься — false.

Верни ТОЛЬКО JSON, без пояснений:
{"items":[{"id":"<id>","present":true|false,"quote":"<фрагмент>"}, ...]}`;

    const user = `ПУНКТЫ ДЛЯ ПРОВЕРКИ:\n${missing.map(m => `- ${m.id}: ${m.label}`).join('\n')}\n\nТЕКСТ ПОЛИТИКИ:\n${policySnippet}`;

    return new Promise(resolve => {
      _httpRequest({
        method: 'POST',
        url: 'https://api.groq.com/openai/v1/chat/completions',
        timeout: 15000,
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + GROQ_KEY },
        data: JSON.stringify({
          model: 'llama-3.3-70b-versatile',
          max_tokens: 600,
          temperature: 0,
          messages: [
            { role: 'system', content: system },
            { role: 'user', content: user }
          ]
        }),
        onload(r) {
          try {
            const j = JSON.parse(r.responseText);
            if (j.error) return resolve(result152);
            const txt = j.choices?.[0]?.message?.content || '';
            const m = txt.match(/\{[\s\S]*\}/);
            if (!m) return resolve(result152);
            const parsed = JSON.parse(m[0]);
            const aiItems = Array.isArray(parsed.items) ? parsed.items : [];

            // Применяем только подтверждения. Никогда не отбираем уже найденное локально.
            const updatedItems = result152.items.map(item => {
              if (item.present) return item;
              const aiHit = aiItems.find(a => a && a.id === item.id && a.present === true);
              if (aiHit) {
                return { ...item, present: true, confirmedBy: 'ai', quote: String(aiHit.quote || '').slice(0, 200) };
              }
              return item;
            });

            const updated = { ...result152, items: updatedItems };
            updated.found = updatedItems.filter(i => i.present).length;
            if (updated.found >= 6) updated.status = 'ok';
            else if (updated.found >= 3) updated.status = 'risk';
            else updated.status = 'violation';
            // per-item flag confirmedBy='ai' уже выставлен выше → UI этого достаточно
            resolve(updated);
          } catch (e) {
            resolve(result152); // fail-safe
          }
        },
        onerror() { resolve(result152); },
        ontimeout() { resolve(result152); }
      });
    });
  }

  async function runAIAnalysis(c, egrul, siteText) {
    // Загружаем подстраницы политики/оферты для AI
    const allLinks = [...c.policyLinks, ...c.offerLinks, ...c.returnLinks, ...c.aboutLinks];
    const fetched = {};
    if (allLinks.length > 0) {
      const results = await Promise.all(allLinks.map(l => fetchUrl(l.href)));
      // Для политики храним полный текст (нужен check152FZ); остальное обрезаем до 3000.
      const tag = (links, label, limit) => {
        const r = links.map(l => {
          const f = results.find(x => x.url === l.href);
          return f && f.ok ? { url: l.href, text: f.text.slice(0, limit) } : null;
        }).filter(Boolean);
        if (r.length > 0) fetched[label] = r;
      };
      tag(c.policyLinks, 'policy', 50000);
      tag(c.offerLinks, 'offer', 3000);
      tag(c.returnLinks, 'return', 3000);
      tag(c.aboutLinks, 'about', 3000);
    }

    // Fallback: политики нет или текст подозрительно короткий (SPA-оболочка,
    // нестандартный текст линка) — пробуем типовые URL-пути на origin сайта.
    const initialPolicyText = (fetched.policy || []).map(p => p.text).join('\n');
    if (initialPolicyText.length < 500 && !scanCancelled) {
      const fallbackPolicy = await discoverPolicyByCommonPaths(c.url);
      if (fallbackPolicy.length > 0) fetched.policy = fallbackPolicy;
    }

    let msg = `URL: ${c.url}\nЗаголовок: ${c.title}\n\nШАПКА: ${c.header}\nПОДВАЛ: ${c.footer}\n\nТЕКСТ:\n${c.bodyText}\n\nTracking: ${c.hasAdScripts?'ЕСТЬ':'нет'}\nCookie-баннер: ${c.hasCookieBanner?'ЕСТЬ':'нет'}\n`;

    // Передаём результат проверки реквизитов через ЕГРЮЛ
    if (egrul && egrul.checked) {
      msg += `\n═══ ПРОВЕРКА РЕКВИЗИТОВ ЧЕРЕЗ ЕГРЮЛ/ЕГРИП (149-ФЗ) ═══\n`;
      if (egrul.ids.inn || egrul.ids.ogrn) {
        msg += `Найдено на сайте: ИНН=${egrul.ids.inn||'—'}, ОГРН=${egrul.ids.ogrn||'—'}\n`;
        if (egrul.result && egrul.result.found && egrul.result.parsed) {
          const p = egrul.result.parsed;
          msg += `Сверка с ФНС: НАЙДЕНО в реестре\n`;
          msg += `  Тип: ${p.type === 'ip' ? 'ИП' : 'ЮЛ'}\n`;
          msg += `  Название: ${p.name}\n`;
          if (p.address) msg += `  Адрес: ${p.address}\n`;
          msg += `  Статус: ${p.isActive ? 'ДЕЙСТВУЮЩАЯ' : 'ПРЕКРАЩЕНА (' + p.reason + ')'}\n`;
          if (p.regDate) msg += `  Дата регистрации: ${p.regDate}\n`;
          msg += `→ Для 149-ФЗ: реквизиты ВЕРИФИЦИРОВАНЫ через ФНС. Если организация действующая — статус "ok".\n`;
          if (!p.isActive) msg += `→ ВНИМАНИЕ: организация ПРЕКРАЩЕНА — это критическое нарушение.\n`;
        } else {
          msg += `Сверка с ФНС: НЕ НАЙДЕНО — ${egrul.result?.error || 'данные не вернулись'}\n`;
          msg += `→ Для 149-ФЗ: указанный на сайте ИНН/ОГРН не найден в ЕГРЮЛ — это нарушение (фейковые реквизиты или ошибка).\n`;
        }
      } else {
        msg += `Реквизиты (ИНН/ОГРН) НЕ НАЙДЕНЫ на сайте\n`;
        msg += `→ Для 149-ФЗ ст.10: явное нарушение, реквизиты владельца обязательны.\n`;
      }
      msg += `═══════════════════════════════════════════\n`;
    }

    // Для AI-промпта политику урезаем до 3000 симв./шт. — контекст модели ограничен.
    // Для check152FZ ниже используем ПОЛНЫЙ текст (хранится в fetched.policy[i].text).
    if (fetched.policy) msg += `\n=== ПОЛИТИКА ===\n${fetched.policy.map(p => `${p.url}\n${p.text.slice(0, 3000)}`).join('\n---\n')}\n`;
    else msg += `\n[ПОЛИТИКА: не найдена]\n`;
    if (fetched.offer) msg += `\n=== ОФЕРТА ===\n${fetched.offer.map(p => `${p.url}\n${p.text.slice(0,1500)}`).join('\n---\n')}\n`;
    else msg += `\n[ОФЕРТА: не найдена]\n`;
    if (fetched.about) msg += `\n=== О КОМПАНИИ ===\n${fetched.about.map(p => `${p.url}\n${p.text.slice(0,1500)}`).join('\n---\n')}\n`;

    // ── Локальный чек-лист 152-ФЗ ст.18.1 (7 пунктов) ──
    const policyText = (fetched.policy || []).map(p => p.text).join('\n\n');
    let result152 = check152FZ(policyText);
    // AI-арбитр: если локально найдено 1-5 из 7 — спрашиваем модель по каждому пропущенному пункту.
    // Никогда не понижает статус, только дополняет. При ошибке/таймауте — возвращает локальный результат.
    // Пропускается если USE_AI=false или нет ключа.
    const groqForArbiter = USE_AI && !!GROQ_KEY;
    if (groqForArbiter && result152.status !== 'no_policy' && result152.found >= 1 && result152.found < 6) {
      result152 = await verify152FZWithAI(policyText, result152);
    }
    if (result152.status !== 'no_policy') {
      msg += `\n═══ ЛОКАЛЬНЫЙ ЧЕК-ЛИСТ 152-ФЗ ст.18.1 ═══\n`;
      msg += `Найдено пунктов: ${result152.found} из ${result152.total}\n`;
      result152.items.forEach(item => {
        msg += `${item.present ? '✓' : '✗'} ${item.label}\n`;
      });
      msg += `Локальный вывод: ${result152.status === 'ok' ? 'политика полная' : result152.status === 'risk' ? 'политика неполная — есть пробелы' : 'критические пробелы'}\n`;
      msg += `→ Используй этот чек-лист как ОСНОВУ для 152-ФЗ. Не пересчитывай заново.\n`;
      msg += `═══════════════════════════════════════════\n`;
    } else {
      msg += `\n═══ 152-ФЗ: ПОЛИТИКА НЕ НАЙДЕНА ═══\nЭто явное нарушение — на сайте должна быть политика конфиденциальности.\n═══════════════════════════════════════════\n`;
    }

    // ── Локальный чек-лист 149-ФЗ ст.10 (5 пунктов: ИНН/ОГРН, название, адрес, email, телефон) ──
    // Берём комбинированный текст: страницы сайта + страницы политики/о компании/контактов.
    const aboutText = (fetched.about || []).map(p => p.text).join('\n');
    const contactText = (fetched.policy || []).map(p => p.text).join('\n') + '\n' + aboutText;
    const text149 = (siteText || '') + '\n' + contactText;
    const result149 = check149FZ(text149);
    msg += `\n═══ ЛОКАЛЬНЫЙ ЧЕК-ЛИСТ 149-ФЗ ст.10 ═══\n`;
    msg += `Найдено пунктов: ${result149.found} из ${result149.total}\n`;
    result149.items.forEach(item => {
      msg += `${item.present ? '✓' : '✗'} ${item.label}\n`;
    });
    msg += `Локальный вывод: ${result149.status === 'ok' ? 'реквизиты на месте' : result149.status === 'risk' ? 'часть реквизитов отсутствует' : 'критические пробелы по реквизитам'}\n`;
    msg += `→ Используй этот чек-лист + результат ЕГРЮЛ выше. Не пересчитывай заново.\n`;
    msg += `═══════════════════════════════════════════\n`;

    // ── Локальный чек-лист ЕРИР (ФЗ №347): маркировка интернет-рекламы ──
    const resultERIR = checkERIR(text149);
    msg += `\n═══ ЛОКАЛЬНЫЙ ЧЕК-ЛИСТ ЕРИР (ФЗ №347) ═══\n`;
    msg += `Рекламный контент: ${resultERIR.hasAdContent ? 'ОБНАРУЖЕН' : 'не обнаружен'}\n`;
    if (resultERIR.hasAdContent) {
      resultERIR.items.forEach(item => {
        msg += `${item.present ? '✓' : '✗'} ${item.label}\n`;
      });
    }
    msg += `Локальный вывод: ${resultERIR.status === 'ok' ? (resultERIR.hasAdContent ? 'реклама маркирована корректно' : 'рекламы не обнаружено') : resultERIR.status === 'risk' ? 'есть рекламный контент, но маркировка неполная' : 'реклама без обязательной маркировки'}\n`;
    msg += `═══════════════════════════════════════════\n`;

    // ── Локальный чек-лист публичной оферты (ГК РФ ст.435, ЗоЗПП ст.26.1) ──
    const resultOffer = checkOffer(text149, c.offerLinks || []);
    msg += `\n═══ ЛОКАЛЬНЫЙ ЧЕК-ЛИСТ ОФЕРТЫ ═══\n`;
    msg += `Коммерческий сайт: ${resultOffer.isCommercial ? `ДА (${resultOffer.kind === 'saas' ? 'SaaS / лицензионный договор' : resultOffer.kind === 'ecommerce' ? 'e-commerce' : resultOffer.kind === 'services' ? 'B2B-услуги / договор подряда' : 'смешанная коммерческая модель'})` : 'нет (информационный сайт)'}\n`;
    if (resultOffer.isCommercial) {
      resultOffer.items.forEach(item => {
        msg += `${item.present ? '✓' : '✗'} ${item.label}\n`;
      });
    }
    msg += `Локальный вывод: ${resultOffer.status === 'ok' ? (resultOffer.isCommercial ? 'оферта и реквизиты на месте' : 'не торговая площадка — оферта не обязательна') : resultOffer.status === 'risk' ? 'часть требований не выполнена' : 'критические пробелы (нет оферты/возврата/реквизитов)'}\n`;
    msg += `═══════════════════════════════════════════\n`;

    // ── Cookie compliance: трекинг + баннер ──
    const policyText_lc = ((fetched.policy || []).map(p => p.text).join('\n')).toLowerCase();
    const policyHasCookies = /cookie|куки|файл[ы]?\s+cookie/i.test(policyText_lc);
    const resultCookie = checkCookieCompliance({
      hasTracking: !!c.hasAdScripts,
      hasCookieBanner: !!c.hasCookieBanner,
      policyHasCookies,
    });
    msg += `\n═══ ЛОКАЛЬНЫЙ ЧЕК COOKIE-COMPLIANCE ═══\n`;
    msg += `Трекинг: ${resultCookie.hasTracking ? 'ОБНАРУЖЕН' : 'не обнаружен'}\n`;
    msg += `Cookie-баннер: ${resultCookie.hasCookieBanner ? 'есть' : 'нет'}\n`;
    msg += `Cookies упоминаются в политике: ${policyHasCookies ? 'да' : 'нет'}\n`;
    msg += `Локальный вывод: ${resultCookie.title}\n`;
    msg += `═══════════════════════════════════════════\n`;

    // ── Локальный чек-лист наркотиков (ст.6.13 КоАП, ФЗ №3) ──
    const resultDrugs = checkDrugs(text149);
    msg += `\n═══ ЛОКАЛЬНЫЙ ЧЕК-ЛИСТ НАРКОТИКИ ═══\n`;
    if (!resultDrugs.hasMentions) {
      msg += `Упоминаний запрещённых веществ не обнаружено.\n`;
    } else {
      msg += `Всего упоминаний: ${resultDrugs.totalMentions} (${resultDrugs.uniqueTerms} уникальных терминов)\n`;
      msg += `С контекстом (УК, медицина, профилактика): ${resultDrugs.withContext}\n`;
      msg += `Без контекста (потенциальные нарушения): ${resultDrugs.withoutContext}\n`;
      if (resultDrugs.mentions.length > 0) {
        msg += `Топ упоминаний:\n`;
        resultDrugs.mentions.slice(0, 10).forEach(m => {
          msg += `  ${m.hasContext ? '✓' : '✗'} «${m.term}» (×${m.count})${m.hasContext ? ' — в контексте' : ' — без контекста'}\n`;
        });
      }
    }
    msg += `Локальный вывод: ${resultDrugs.status === 'ok' ? (resultDrugs.hasMentions ? 'упоминания в допустимом контексте' : 'упоминаний нет') : resultDrugs.status === 'risk' ? 'есть упоминания без явного контекста — нужна проверка' : 'упоминания без контекста — потенциальное нарушение ст.6.13 КоАП'}\n`;
    msg += `═══════════════════════════════════════════\n`;

    // ── Если AI отключён или нет ключа — собираем отчёт только из локальных чек-листов ──
    const groqAvailable = USE_AI && !!GROQ_KEY;
    if (!groqAvailable) {
      try { console.log('[Слеза] Groq пропущен (USE_AI=' + USE_AI + ', key=' + (GROQ_KEY ? 'есть' : 'нет') + '). Используем локальные чек-листы.'); } catch(_) {}
      return {
        site_name: c.title || c.url,
        site_type: '',
        summary: 'Отчёт собран из локальных детерминированных проверок (без AI).',
        checks: buildLocalChecks({ result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie, egrul }),
        fetched, result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie,
      };
    }

    return new Promise(resolve => {
      _httpRequest({
        method: 'POST',
        url: 'https://api.groq.com/openai/v1/chat/completions',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + GROQ_KEY },
        data: JSON.stringify({
          model: 'llama-3.3-70b-versatile',
          max_tokens: 2500,
          temperature: 0.1,
          messages: [
            { role: 'system', content: SYSTEM },
            { role: 'user', content: msg }
          ]
        }),
        onload(r) {
          try {
            const j = JSON.parse(r.responseText);
            if (j.error) throw new Error(j.error.message);
            const txt = j.choices?.[0]?.message?.content || '';
            const m = txt.match(/\{[\s\S]*\}/);
            if (!m) throw new Error('parse');
            const parsed = JSON.parse(m[0]);
            resolve({ ...parsed, fetched, result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie });
          } catch(e) {
            // Groq упал/rate-limit/parse — собираем отчёт из локальных результатов, не теряем данные
            const localChecks = buildLocalChecks({ result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie, egrul });
            resolve({ error: e.message, checks: localChecks, summary: 'Groq недоступен — отчёт собран из локальных проверок.', fetched, result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie });
          }
        },
        onerror() {
          const localChecks = buildLocalChecks({ result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie, egrul });
          resolve({ error: 'net', checks: localChecks, summary: 'Groq недоступен (сетевая ошибка) — отчёт собран из локальных проверок.', fetched, result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie });
        },
        ontimeout() {
          const localChecks = buildLocalChecks({ result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie, egrul });
          resolve({ error: 'timeout', checks: localChecks, summary: 'Groq не ответил вовремя — отчёт собран из локальных проверок.', fetched, result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie });
        }
      });
    });
  }

  const ST = {
    violation:{label:'НАРУШЕНИЕ',cls:'violation'},
    risk:     {label:'РИСК',     cls:'risk'},
    ok:       {label:'В ПОРЯДКЕ',cls:'ok'},
    unknown:  {label:'НЕТ ДАННЫХ',cls:'unknown'},
  };

  // Заглушки для 5 AI-законов — рендерятся всегда, даже если Groq недоступен.
  // Каждая запись имеет ЯВНЫЙ id — используется для сопоставления с локальными
  // чекерами и render-блоками. Раньше использовали substring matching по law_code
  // (ch.law_code.includes('152-ФЗ')) — было хрупко при пересекающихся кодах.
  const AI_LAW_STUBS = [
    { id: 'drugs',  law: 'Упоминание наркотиков',             law_code: 'ст.6.13 КоАП, ФЗ №3',         fine: 'до 1 500 000 руб.',        status: 'unknown', issue: '', location: '', found_text: '', action: '' },
    { id: 'law152', law: '152-ФЗ — персональные данные',       law_code: '152-ФЗ, ст.13.11 КоАП',       fine: 'до 300 000 руб.',           status: 'unknown', issue: '', location: '', found_text: '', action: '' },
    { id: 'erir',   law: 'Маркировка рекламы (ЕРИР)',          law_code: 'ФЗ №347, ст.14.3 КоАП',       fine: '100 000 — 500 000 руб.',    status: 'unknown', issue: '', location: '', found_text: '', action: '' },
    { id: 'law149', law: '149-ФЗ — информация о владельце',    law_code: '149-ФЗ ст.10, ст.13.31 КоАП', fine: 'до 100 000 руб.',           status: 'unknown', issue: '', location: '', found_text: '', action: '' },
    { id: 'offer',  law: 'Публичная оферта и условия возврата',law_code: 'ГК РФ ст.435, ЗоЗПП ст.26.1', fine: 'до 500 000 руб.',           status: 'unknown', issue: '', location: '', found_text: '', action: '' },
  ];

  // Текстовые шаблоны issue/action по каждому закону на основе локальных результатов.
  // Используется когда Groq отключён или недоступен — отчёт остаётся полным.
  function buildLocalChecks({ result152, result149, resultERIR, resultOffer, resultDrugs, resultCookie, egrul, siteType = 'auto' }) {
    const out = AI_LAW_STUBS.map(s => ({ ...s }));

    // 1) Наркотики
    const drugs = out.find(c => c.id === 'drugs');
    if (drugs && resultDrugs) {
      drugs.status = resultDrugs.status;
      if (!resultDrugs.hasMentions) {
        drugs.issue = 'Упоминаний запрещённых веществ не обнаружено';
        drugs.action = '—';
      } else if (resultDrugs.status === 'ok') {
        drugs.issue = `${resultDrugs.totalMentions} упоминаний в допустимом контексте (УК, медицина, профилактика)`;
        drugs.action = '—';
      } else {
        const top = resultDrugs.mentions.filter(m => !m.hasContext).slice(0, 3).map(m => `«${m.term}»`).join(', ');
        drugs.issue = `${resultDrugs.withoutContext} упоминаний без явного контекста: ${top}`;
        drugs.found_text = top;
        drugs.action = resultDrugs.status === 'violation'
          ? 'Удалить упоминания или добавить ссылку на статью УК / профилактический контекст. По ст.6.13 КоАП — пропаганда наркотиков'
          : 'Добавить дисклеймер или контекст (статья УК, медицинская публикация, новость о борьбе)';
      }
      if (siteType === 'media' && resultDrugs.hasMentions) {
        if (resultDrugs.withoutContext < 3) { drugs.status = 'ok'; drugs.action = '—'; }
        else if (resultDrugs.withoutContext < 5) drugs.status = 'risk';
      }
    }

    // 2) 152-ФЗ + Cookie compliance
    const law152 = out.find(c => c.id === 'law152');
    if (law152 && result152) {
      law152.status = result152.status === 'no_policy' ? 'violation' : result152.status;
      // Cookie может ужесточить статус: policy ok + cookie violation → risk
      if (resultCookie) {
        if (resultCookie.status === 'violation' && law152.status === 'ok') law152.status = 'risk';
        else if (resultCookie.status === 'risk'  && law152.status === 'ok') law152.status = 'risk';
      }
      const cookieNote = resultCookie && resultCookie.status !== 'ok'
        ? ` Дополнительно: ${resultCookie.title.toLowerCase()}.`
        : '';
      const cookieAction = resultCookie && resultCookie.status === 'violation'
        ? ' Добавить cookie-баннер с согласием пользователя на использование трекинга.'
        : resultCookie && resultCookie.status === 'risk'
          ? ' Рекомендуется добавить активный cookie-баннер на странице.'
          : '';
      if (result152.status === 'no_policy') {
        law152.issue = 'Политика конфиденциальности не найдена на сайте.' + cookieNote;
        law152.action = 'Создать и разместить политику обработки персональных данных (152-ФЗ ст.18.1) — обязательна для всех сайтов, собирающих данные.' + cookieAction;
      } else if (result152.status === 'ok') {
        law152.issue = `Политика конфиденциальности соответствует требованиям 152-ФЗ (${result152.found} из ${result152.total} пунктов).` + cookieNote;
        law152.action = cookieAction.trim() || '—';
      } else {
        const missing = result152.items.filter(i => !i.present).map(i => i.label.toLowerCase()).join('; ');
        law152.issue = `Политика неполная — отсутствует: ${missing}.` + cookieNote;
        law152.action = (result152.status === 'violation'
          ? 'Переработать политику с учётом всех 7 пунктов ст.18.1 152-ФЗ.'
          : 'Дополнить отсутствующие обязательные пункты политики.') + cookieAction;
      }
    }

    // 3) ЕРИР
    const erir = out.find(c => c.id === 'erir');
    if (erir && resultERIR) {
      erir.status = resultERIR.status;
      if (!resultERIR.hasAdContent) {
        erir.issue = 'Рекламного контента не обнаружено';
        erir.action = '—';
      } else if (resultERIR.status === 'ok') {
        erir.issue = 'Реклама маркирована корректно: токен ERID, метка «реклама», информация о рекламодателе';
        erir.action = '—';
      } else {
        const missing = resultERIR.items.filter(i => !i.present).map(i => i.label.toLowerCase()).join('; ');
        erir.issue = `Реклама без обязательной маркировки: отсутствует ${missing}`;
        erir.action = resultERIR.status === 'violation'
          ? 'Получить ERID через ОРД, добавить метку «реклама» и информацию о рекламодателе. С 01.09.2022 это обязательно'
          : 'Дополнить маркировку рекламных публикаций';
      }
    }

    // 4) 149-ФЗ
    const law149 = out.find(c => c.id === 'law149');
    if (law149 && result149) {
      const egrulInactive = egrul?.result?.parsed && egrul.result.parsed.isActive === false;
      law149.status = egrulInactive ? 'violation' : result149.status;
      if (egrulInactive) {
        law149.issue = `Организация прекращена в ЕГРЮЛ — ${egrul.result.parsed.reason || 'деятельность прекращена'}`;
        law149.action = 'Обновить реквизиты на сайте — указанная организация не ведёт деятельность';
      } else if (result149.status === 'ok') {
        law149.issue = `Обязательные реквизиты владельца на сайте указаны (${result149.found} из ${result149.total})`;
        law149.action = '—';
      } else {
        const missing = result149.items.filter(i => !i.present).map(i => i.label.toLowerCase()).join('; ');
        law149.issue = `Отсутствует: ${missing}`;
        law149.action = 'Добавить недостающие реквизиты владельца (149-ФЗ ст.10): ИНН, ОГРН, полное наименование, адрес, контакты';
      }
    }

    // 5) Оферта
    const offer = out.find(c => c.id === 'offer');
    if (offer && resultOffer) {
      offer.status = resultOffer.status;
      const kindHuman = resultOffer.kind === 'saas' ? 'SaaS / лицензионный договор' :
                        resultOffer.kind === 'ecommerce' ? 'торговая площадка' :
                        resultOffer.kind === 'services' ? 'B2B-услуги / договор подряда' : null;
      if (!resultOffer.isCommercial) {
        offer.issue = 'Признаков торговой / SaaS-деятельности не обнаружено — оферта не обязательна';
        offer.action = '—';
      } else if (resultOffer.status === 'ok') {
        offer.issue = `Публичная оферта, условия расторжения / возврата и реквизиты на месте (${kindHuman})`;
        offer.action = '—';
      } else {
        const missing = resultOffer.items.filter(i => !i.present).map(i => i.label.toLowerCase()).join('; ');
        offer.issue = `Отсутствует: ${missing}${kindHuman ? ` (${kindHuman})` : ''}`;
        offer.action = resultOffer.status === 'violation'
          ? (resultOffer.kind === 'saas'
              ? 'Опубликовать лицензионный договор / публичную оферту с условиями расторжения и реквизитами лицензиара'
              : resultOffer.kind === 'services'
                ? 'Опубликовать публичную оферту на оказание услуг с порядком расторжения и реквизитами исполнителя'
                : 'Создать публичную оферту с условиями возврата (ЗоЗПП ст.26.1 — возврат в течение 7 дней) и указать реквизиты продавца')
          : 'Дополнить оферту недостающими элементами';
      }
      if (siteType === 'media' && offer) {
        offer.status = 'ok';
        offer.issue  = 'Информационный/медиа-сайт — публичная оферта не требуется (ЗоЗПП ст.26.1 применяется только к интернет-торговле)';
        offer.action = '—';
      }
    }

    return out;
  }

