        patterns: [
          /(?:^|[\s>,.;:])ИНН[\s:№.]*[0-9]{10,12}/i,
          /(?:^|[\s>,.;:])ОГРН(?:ИП)?[\s:№.]*[0-9]{13,15}/i,
          /(?:^|[\s>])(ООО|ОАО|ЗАО|ПАО|АО|ИП)\s+[«"А-ЯЁ]/,
          /(?:^|[\s>])(ООО|АО|ПАО|ЗАО|ОАО)\s+[«"][^"»]{2,80}["»]/,
