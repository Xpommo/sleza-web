        ${stats ? `<br>// приоритизация: <span style="color:#4ade80">📰 ${stats.highScanned} из ${stats.totalHighFound} контентн.</span> · <span style="color:#94a3b8">🏢 ${stats.mid} корпорат.</span>${stats.low > 0 ? ` · <span style="color:#64748b">📄 ${stats.low} прочих</span>` : ''}${stats.skipped > 0 ? ` · <span style="color:#475569">✗ ${stats.skipped} тех.страниц пропущено</span>` : ''}${stats.yearRange ? `<br>// покрытие архива: <span style="color:#60a5fa">📅 ${stats.yearRange}</span> · ${stats.yearsCovered.length} ${plural(stats.yearsCovered.length, 'год', 'года', 'лет')}` : ''}` : ''}
