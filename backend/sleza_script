        patterns: [
          /ответствен[ныйогомеи]+\s+за\s+(обработк|защит|организац)/,
          /(адрес|email|e-?mail|телефон|тел\.?).{0,100}(обраб|защит|оператор|персональн)/,
          /(оператор|компани).{0,150}(@|почт[аеуыой]\s+электронн|электронн[аоы][яе]\s+почт)/,
          /[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}/i,
          /(контакт|связ[аь])[а-я]{0,10}\s+(оператор|с\s+нами|для\s+связи)/,
          /(\+7|8)[\s\(]*\d{3}[\s\)\-]*\d{3}[\s\-]*\d{2}[\s\-]*\d{2}/,
        ],
        keywords: ['ответственный за обработку', 'обратиться к нам', 'связаться с нами', 'контакты оператора', 'контактная информация', 'для связи', 'наши контакты', 'email:', 'e-mail:', 'электронная почта']
      },
      {
        id: 'third_parties',
        label: 'Передача данных третьим лицам',
        patterns: [
          /треть[ьиими]+\s+лиц/,
          /треть.{0,3}лиц/,
          /(передач[аеиую]|переда[еютюся]+).{0,100}(треть|сторонн|партн|контрагент)/,
          /трансгранич/,
          /(не\s+перед[аеютюся]+|без\s+согласи).{0,50}треть/,
          /(раскрыти[еюй]|предоставлени[еюй]).{0,40}(треть|сторонн)/,
        ],
        keywords: ['третьим лицам', 'третьих лиц', 'третьими лицами', 'передача данных', 'трансграничная передача', 'третьи лица', 'передаче данных']
      }
    ];

    const result = { items: [], found: 0, total: 7, status: 'unknown' };
    for (const c of checks) {
      const hasSection = sectionHeadingHits[c.id] && sectionHeadingHits[c.id].test(policyText);
      const hasPattern = c.patterns.some(p => p.test(t));
      const hasKeyword = c.keywords.some(k => t.includes(k.toLowerCase()));
      const present = hasSection || hasPattern || hasKeyword;
      result.items.push({ id: c.id, label: c.label, present, confirmedBy: present ? 'local' : null });
      if (present) result.found++;
    }

    if (result.found >= 6) result.status = 'ok';
    else if (result.found >= 3) result.status = 'risk';
    else result.status = 'violation';

    return result;
  }

  // ── Чек-лист 149-ФЗ ст.10 — информация о владельце сайта ──
  // На сайте организации должны быть указаны:
  // 1. ИНН или ОГРН (для идентификации владельца)
  // 2. Полное наименование (ООО/АО/ИП) или ФИО ИП
  // 3. Адрес юр. лица или ИП
  // 4. Email для связи
  // 5. Контактный телефон
  function check149FZ(fullText) {
    if (!fullText || fullText.length < 50) {
      return { found: 0, total: 5, items: [], status: 'unknown' };
    }

    // Лидирующая "граница слова" для кириллицы: либо начало строки, либо разделитель.
    // \b в JS работает только с латиницей/цифрами, поэтому \bИНН не цепляется к "ИНН 123".
    const checks = [
      {
        id: 'inn_ogrn',
        label: 'ИНН или ОГРН организации',
        patterns: [
          /(?:^|[\s>,.;:])ИНН[\s:№.]*[0-9]{10,12}(?:\D|$)/i,
          /(?:^|[\s>,.;:])ОГРН(?:ИП)?[\s:№.]*[0-9]{13,15}(?:\D|$)/i,
        ],
      },
      {
        id: 'name',
        label: 'Полное наименование (ООО/АО/ИП)',
        patterns: [
          /(?:^|[\s>])(ООО|ОАО|ЗАО|ПАО|АО|НКО|АНО|НП)\s+["«][^"»]{2,80}["»]/,
          /(?:^|[\s>])(ООО|ОАО|ЗАО|ПАО|АО)\s+[А-ЯЁ][а-яёА-ЯЁ\w\-]{1,40}(?=[\s,.]|$)/,
          /общество\s+с\s+ограниченной\s+ответственностью/i,
          /(публичное|непубличное|открытое|закрытое)\s+акционерное\s+общество/i,
          /индивидуальный\s+предприниматель\s+[А-ЯЁ]/i,
          /(?:^|[\s>])ИП\s+[А-ЯЁ][а-яё]+\s+[А-ЯЁ]/,
        ],
      },
      {
        id: 'email',
        label: 'Email для связи',
        patterns: [
          /[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}/i,
        ],
      },
      {
        id: 'phone',
        label: 'Контактный телефон',
        patterns: [
          /(?:\+7|(?:^|\D)8)[\s\(\-]*\d{3}[\s\)\-]*\d{3}[\s\-]*\d{2}[\s\-]*\d{2}(?:\D|$)/,
        ],
      },
      {
        id: 'address',
        label: 'Юридический или фактический адрес',
        patterns: [
          // Почтовый индекс + город / регион
          /(?:^|\D)\d{6}[,\s]+(г\.|город|респ\.|область|край|москва|санкт-петербург)/i,
          // Москва/Питер + улица/проспект
          /(г\.\s*Москва|г\.\s*Санкт-Петербург|москва|санкт-петербург)[,\s]+(ул\.|улица|пр\.|проспект|пер\.|переулок|наб\.|набережная|пл\.|площадь|шоссе|бульвар|проезд|тупик)/i,
          // улица + дом
          /(ул\.|улица|пр\.|проспект|пер\.|переулок|наб\.|набережная)\s+[А-ЯЁ][а-яё]+[,\s\.]+(д\.|дом)\s*\d+/i,
          // явная подпись "юридический адрес: ..."
          /юридический\s+адрес[\s:]+[А-ЯЁ\d]/i,
          /почтовый\s+адрес[\s:]+[А-ЯЁ\d]/i,
          /адрес\s+(организации|компании|юр[. ]+лица)/i,
        ],
      },
    ];

    const result = { items: [], found: 0, total: checks.length, status: 'unknown' };
    for (const c of checks) {
      const present = c.patterns.some(p => p.test(fullText));
      result.items.push({ id: c.id, label: c.label, present });
      if (present) result.found++;
    }

    if (result.found >= 4) result.status = 'ok';
    else if (result.found >= 2) result.status = 'risk';
    else result.status = 'violation';

    // ИНН/ОГРН — самый критичный реквизит: без него ok → risk
    const hasInnOgrn = result.items.find(i => i.id === 'inn_ogrn')?.present;
    if (!hasInnOgrn && result.status === 'ok') result.status = 'risk';

    return result;
  }

  // ── Чек-лист ЕРИР: маркировка интернет-рекламы (ФЗ №347) ──
  // Логика:
  // 1) Признаки рекламного контента ВООБЩЕ — есть/нет
  // 2) Если есть — проверяем erid-токен, метку "реклама", информацию о рекламодателе
  // Без AI: даёт предварительную оценку. С AI: вердикт уточняется.
  function checkERIR(fullText) {
    if (!fullText || fullText.length < 100) {
      return { found: 0, total: 3, items: [], status: 'unknown', hasAdContent: false };
    }
    const t = fullText.toLowerCase();

    // 1) Признаки рекламного контента
    const adMarkers = [
      /на\s+правах\s+реклам/,
      /рекламн[ыоа][йея]\s+(материал|публикац|пост|пуш)/,
      /партн[её]рск[ийояую][й]?\s+материал/,
      /спонсорск[ийояую][й]?\s+(материал|публикац|пост|контент)/,
      /промо\s*[\-—:]\s*материал/,
      /рекламодател/,
      /sponsored\s+(content|post|by)/i,
      /\bpromo(ted)?\b/i,
    ];
    const hasAdContent = adMarkers.some(p => p.test(t));

    const checks = [
      {
        id: 'erid_token',
        label: 'Токен ERID присутствует',
        patterns: [
          /\berid[\s:=]+[\w\-]{6,}/i,
          /erid[\s\-:]*[0-9a-z]{6,}/i,
        ],
      },
      {
        id: 'ad_marker',
        label: 'Метка «реклама» / «на правах рекламы»',
        // /i на всех паттернах: эти проверки гоняются на оригинальном тексте
        // (не на lowercase), а «На правах рекламы» в начале предложения — норма.
        patterns: [
          /(?:^|[\s>])реклама(?:[\s,.:;]|$)/i,
          /на\s+правах\s+реклам/i,
          /рекламн[ыоа][йея]\s+(материал|публикац|пост)/i,
        ],
      },
      {
        id: 'advertiser_info',
        label: 'Информация о рекламодателе (ИНН/название)',
        patterns: [
          /рекламодател[ьяе][\s:]+[^.\n]{5,150}/i,
          /(?:^|[\s>])(ООО|ОАО|ЗАО|ПАО|АО|ИП)\s+[«"А-ЯЁ]/,
          /(?:^|[\s>,.;:])ИНН[\s:№.]*[0-9]{10,12}/i,
        ],
      },
    ];

    const result = { items: [], found: 0, total: checks.length, status: 'unknown', hasAdContent };
    for (const c of checks) {
      const present = c.patterns.some(p => p.test(fullText));
      result.items.push({ id: c.id, label: c.label, present });
      if (present) result.found++;
    }

    // Логика статуса:
    // - Нет рекламного контента → ok (реклама не используется, маркировка не требуется)
    // - Есть реклама и все 3 признака → ok
    // - Есть реклама и 2 из 3 → risk
    // - Есть реклама и <2 → violation
    if (!hasAdContent) {
      result.status = 'ok';
    } else if (result.found === 3) {
      result.status = 'ok';
    } else if (result.found >= 2) {
      result.status = 'risk';
    } else {
      result.status = 'violation';
    }

    return result;
  }

  // ── Чек-лист публичной оферты и условий возврата (ГК РФ ст.435, ЗоЗПП ст.26.1) ──
  // Актуально для e-commerce и любого сайта с продажей товаров/услуг.
  // Логика:
  // 1) Определяем — это коммерческий сайт (есть признаки торговли)?
  // 2) Если да — проверяем наличие оферты, условий возврата, информации о продавце
  // ── Чек cookie-compliance (152-ФЗ + ст.13.11 КоАП в части автоматизированной обработки) ──
  // Логика юриста: если сайт собирает cookies/использует трекинг — нужен баннер согласия.
  // Если трекинга нет — баннер не обязателен.
  function checkCookieCompliance({ hasTracking, hasCookieBanner, policyHasCookies }) {
    // Дополнительный сигнал: если в политике явно описаны cookies — это компенсирует отсутствие баннера
    if (!hasTracking) {
      return {
        hasTracking: false, hasCookieBanner, policyHasCookies,
        status: 'ok',
        title: 'Трекинг не обнаружен',
        message: 'Аналитические скрипты не найдены — баннер согласия на cookie не обязателен.',
      };
    }
    if (hasCookieBanner) {
      return {
        hasTracking: true, hasCookieBanner: true, policyHasCookies,
        status: 'ok',
        title: 'Баннер согласия на cookie присутствует',
        message: 'Трекинг обнаружен, согласие на использование cookie запрашивается у пользователя.',
      };
    }
    if (policyHasCookies) {
      return {
        hasTracking: true, hasCookieBanner: false, policyHasCookies: true,
        status: 'risk',
        title: 'Баннер согласия на cookie отсутствует, но cookies описаны в политике',
        message: 'Трекинг работает, политика упоминает cookies — но активного баннера согласия нет. Это серая зона: рекомендуется добавить баннер.',
      };
    }
    return {
      hasTracking: true, hasCookieBanner: false, policyHasCookies: false,
      status: 'violation',
      title: 'Баннер согласия на cookie отсутствует',
      message: 'Сайт использует трекинг (Яндекс.Метрика / GA / Pixel / и т.п.), но не получает явного согласия пользователя на обработку cookie. Нарушение 152-ФЗ ст.9 и ст.6 в части автоматизированной обработки.',
    };
  }

  function checkOffer(fullText, offerLinks) {
    if (!fullText || fullText.length < 100) {
      return { found: 0, total: 4, items: [], status: 'unknown', isCommercial: false, kind: null };
    }
    const t = fullText.toLowerCase();

    // 1) Признаки коммерческого сайта — два независимых пула:
    //    e-commerce (товары, доставка, корзина) и SaaS/услуги (лицензия, тариф, подписка).
    //    Считаем коммерческим если в ЛЮБОМ пуле ≥2 совпадения.
    // Cyrillic-aware границы слов: `\b` в JS работает только с латиницей/цифрами.
    // Для русских терминов используем lookaround на не-буквенно-цифровой символ.
    const BOUND = '(?:^|[^а-яёa-z0-9_])';
    const ENDB  = '(?=[^а-яёa-z0-9_]|$)';
    const ecommerceMarkers = [
      new RegExp(BOUND + '(купить|заказать|оформить\\s+заказ|добавить\\s+в\\s+корзину)' + ENDB, 'i'),
      new RegExp(BOUND + 'корзин[аеуыой]' + ENDB, 'i'),
      new RegExp(BOUND + '(стоимость|цена|руб(?:\\.|лей)?|₽)' + ENDB + '.{0,50}(\\d{2,})', 'i'),
      new RegExp(BOUND + '(доставка|самовывоз|курьер|пункт\\s+выдач|постамат)' + ENDB, 'i'),
      /(\d+[\s\-]*₽|\d+[\s\-]*руб)/i,
      new RegExp(BOUND + '(оплат[аеу]|оплачивать)' + ENDB, 'i'),
      /интернет[\-\s]?магазин/i,
      /онлайн[\-\s]?(магазин|шоп|маркет)/i,
      new RegExp(BOUND + '(покупател[ьяюие]+|продавц[аеуо]+)' + ENDB, 'i'),
      /(каталог\s+товар|ассортимент\s+товар)/i,
    ];
    const saasMarkers = [
      /лицензиар[аеуо]?/i,
      /лицензиат[аеуо]?/i,
      /лицензионн[ыоаеми]+\s+(договор|соглашен|вознагражден|плат)/i,
      /программн[оаеыми]+\s+обеспечен/i,
      /(подписк|тариф|абонементн)[а-яё]+\s+(плат|стоимост|период|оплат)/i,
      new RegExp(BOUND + '(тариф|подписка|абонемент)[а-яё]*' + ENDB, 'i'),
      /личн[ыоом]+\s+кабинет/i,
      /(SaaS|сервис|услуг[аеи]+).{0,30}(оплат|стоимост|тариф|подписк)/i,
    ];
    // B2B-сервисы / рекламные агентства / любые договоры подряда — третий тип
    const servicesMarkers = [
      new RegExp(BOUND + 'исполнител[ьяюуео]+' + ENDB, 'i'),
      new RegExp(BOUND + 'заказчик[аеуо]*' + ENDB, 'i'),
      /(оказан|оказыва|выполнен|выполня)[а-яё]+\s+(услуг|работ)/i,
      /акт\s+(сдач[ие]|приёмки|приемки|выполненн)/i,
      /технич[а-яё]+\s+задани/i,
      /рекламн[ыоаеми]+\s+(услуг|агентств|кампани|продукц)/i,
      /(маркетингов|консалтингов|агентск)[а-яё]+\s+услуг/i,
      /(договор|контракт)\s+(подряд|оказан|возмездн)/i,
    ];
    const ecommerceHits = ecommerceMarkers.filter(p => p.test(t)).length;
    const saasHits      = saasMarkers.filter(p => p.test(t)).length;
    const servicesHits  = servicesMarkers.filter(p => p.test(t)).length;
    const isCommercial  = ecommerceHits >= 2 || saasHits >= 2 || servicesHits >= 2;
    // Определяем доминирующий тип (для UI и labels)
